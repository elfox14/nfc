# Environment configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
# Replace with your actual MongoDB Atlas connection string
MONGO_URI=YOUR_MONGO_URI_HERE
MONGO_DB=nfc_db
MONGO_DESIGNS_COLL=designs
MONGO_BACKGROUNDS_COLL=backgrounds

# Security
JWT_SECRET=YOUR_JWT_SECRET_HERE
ADMIN_TOKEN=YOUR_ADMIN_TOKEN_HERE
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Base URLs
PUBLIC_BASE_URL=https://your-domain.com/nfc
SITE_BASE_URL=https://your-domain.com

# Internal server URL (for CSP headers — keep out of public code)
INTERNAL_SERVER_URL=https://your-render-app.onrender.com

# Upload Base URL (used by both Node.js server and PHP upload.php)
UPLOAD_BASE_URL=https://uploads.your-domain.com

# PHP Upload Configuration (set on hosting panel for upload.php)
# ALLOWED_ORIGINS=https://your-domain.com,https://uploads.your-domain.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Email Service (optional)
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=YOUR_EMAIL_HERE
EMAIL_PASS=YOUR_EMAIL_PASSWORD_HERE
EMAIL_FROM=noreply@your-domain.com
