# Environment configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/?appName=your_app
MONGO_DB=mcnfc
MONGO_DESIGNS_COLL=designs
MONGO_BACKGROUNDS_COLL=backgrounds

# Security
# Generate both secrets with a cryptographically secure random generator, for example: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_or_more
TOKEN_HASH_SECRET=replace_with_a_different_64_hex_chars_or_more
TRUST_PROXY=true
ALLOWED_ORIGINS=https://www.mcprim.com,https://mcprim.com

# Base URLs
PUBLIC_BASE_URL=https://mcprim.com/nfc
SITE_BASE_URL=https://mcprim.com

# Cloudinary (Optional, for image uploads if used)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# External Upload Service (Optional)
EXTERNAL_UPLOAD_URL=https://uploads.yourdomain.com/upload.php
UPLOAD_SECRET=your_upload_secret

# Email Configuration
EMAIL_PROVIDER=console
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME="MC PRIME NFC"

# Admin
# Preferred: store only the SHA-256 hash of the admin token.
ADMIN_TOKEN_SHA256=sha256_hex_of_your_admin_token
# Legacy fallback, avoid using in production once ADMIN_TOKEN_SHA256 is configured.
ADMIN_TOKENH=your_admin_token_here

# Google OAuth (Optional, for social login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Render Hosting (Optional)
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
