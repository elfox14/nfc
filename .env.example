# Environment configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.
#
# Generate secure secrets with:  openssl rand -base64 32

NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB=nfc_db
MONGO_DESIGNS_COLL=designs
MONGO_BACKGROUNDS_COLL=backgrounds

# Security
# REQUIRED — generate with: openssl rand -base64 32
JWT_SECRET=<GENERATE_STRONG_SECRET>
TRUST_PROXY=false

# CORS — comma-separated list of allowed origins (required in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Base URLs
PUBLIC_BASE_URL=https://your-domain.com/nfc
SITE_BASE_URL=https://your-domain.com

# Cloudinary (Optional, for image uploads if used)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=<GENERATE_STRONG_SECRET>

# External Upload Service (upload.php receiver)
# Both are required when using the PHP upload receiver
EXTERNAL_UPLOAD_URL=https://example.com/upload
# REQUIRED — generate with: openssl rand -base64 32
UPLOAD_SECRET=<GENERATE_STRONG_SECRET>
# REQUIRED in production — comma-separated list of allowed CORS origins for upload.php
UPLOAD_ALLOWED_ORIGINS=https://your-domain.com
UPLOAD_BASE_URL=https://uploads.your-domain.com/uploads

# Email Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=<YOUR_SENDGRID_API_KEY>
EMAIL_FROM_ADDRESS=noreply@your-domain.com
EMAIL_FROM_NAME="MC PRIME NFC"

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=<GENERATE_STRONG_SECRET>

# --- Secret Rotation ---
# If any secret is compromised:
# 1. Generate a new secret: openssl rand -base64 32
# 2. Update the secret in your hosting/Render environment variables
# 3. Redeploy the server — existing tokens signed with the old secret will be invalidated
# 4. If UPLOAD_SECRET was leaked, update it on both the PHP server and Render
