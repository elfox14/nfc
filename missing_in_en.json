{
  "phone-btn-font": "<select class=\"lp-input lp-select\" id=\"phone-btn-font\" style=\"height:32px; padding-top:0; padding-bottom:0;\">\n<option value=\"'Poppins', sans-serif\">Poppins</option>\n<option value=\"'Tajawal', sans-serif\">Tajawal</option>\n<option value=\"'Cairo', sans-serif\">Cairo</option>\n</select>",
  "qr-placement-btns": "<div class=\"lp-placement-btns\" id=\"qr-placement-btns\">\n<label class=\"lp-place-btn\">\n<input name=\"placement-qr\" type=\"radio\" value=\"front\"/> <i class=\"fas fa-id-card\"></i> أمامي\n                                </label>\n<label class=\"lp-place-btn lp-place-active\">\n<input checked=\"\" name=\"placement-qr\" type=\"radio\" value=\"back\"/> <i class=\"fas fa-id-card-alt\"></i> خلفي\n                                </label>\n</div>",
  "phone-btn-controls": "<div id=\"phone-btn-controls\">\n<div class=\"lp-section lp-grid-2\" style=\"border:none; padding-bottom:0px;\">\n<div>\n<label class=\"lp-label\">لون الزر</label>\n<div class=\"lp-color-pick-wrap\" style=\"margin-top:2px;\">\n<input class=\"lp-color-pick\" id=\"phone-btn-bg-color\" type=\"color\" value=\"#4da6ff\"/>\n</div>\n</div>\n<div style=\"display:flex; flex-direction:column; align-items:flex-end;\">\n<label class=\"lp-label\">لون النص</label>\n<div class=\"lp-color-pick-wrap\" style=\"margin-top:2px;\">\n<input class=\"lp-color-pick\" id=\"phone-btn-text-color\" type=\"color\" value=\"#ffffff\"/>\n</div>\n</div>\n</div>\n<div class=\"lp-section\">\n<label class=\"lp-label\">حجم الخط</label>\n<div class=\"lp-slider-wrap\">\n<input class=\"lp-slider\" id=\"phone-btn-font-size\" max=\"24\" min=\"10\" oninput=\"this.nextElementSibling.textContent=this.value+'px'\" type=\"range\" value=\"12\"/>\n<span class=\"lp-slider-val\">12px</span>\n</div>\n</div>\n<div class=\"lp-section\">\n<label class=\"lp-label\">التباعد (Padding)</label>\n<div class=\"lp-slider-wrap\">\n<input class=\"lp-slider\" id=\"phone-btn-padding\" max=\"16\" min=\"4\" oninput=\"this.nextElementSibling.textContent=this.value+'px'\" type=\"range\" value=\"6\"/>\n<span class=\"lp-slider-val\">6px</span>\n</div>\n</div>\n<div class=\"lp-section\" style=\"border:none; padding-bottom:0;\">\n<label class=\"lp-label\">الخط</label>\n<select class=\"lp-input lp-select\" id=\"phone-btn-font\" style=\"height:32px; padding-top:0; padding-bottom:0;\">\n<option value=\"'Poppins', sans-serif\">Poppins</option>\n<option value=\"'Tajawal', sans-serif\">Tajawal</option>\n<option value=\"'Cairo', sans-serif\">Cairo</option>\n</select>\n</div>\n</div>",
  "phones-accordion": "<details class=\"fieldset-accordion lp-accordion\" id=\"phones-accordion\">\n<summary class=\"lp-summary\">\n<span class=\"lp-summary-icon\"><i class=\"fas fa-phone-alt\"></i></span>\n<span>أرقام الهواتف</span>\n<label class=\"lp-toggle\" onclick=\"event.stopPropagation()\" title=\"إظهار / إخفاء\">\n<input checked=\"\" id=\"visibility-phones\" type=\"checkbox\"/>\n<span class=\"lp-toggle-track\"><span class=\"lp-toggle-thumb\"></span></span>\n</label>\n</summary>\n<div class=\"fieldset-content lp-body\">\n<!-- ① Manage Numbers Card -->\n<div class=\"lp-card\">\n<div class=\"lp-card-header\">\n<span class=\"lp-card-title\"><i class=\"fas fa-list-ol\"></i> إدارة الأرقام</span>\n</div>\n<div class=\"lp-section\" style=\"padding-top:0; border:none;\">\n<div id=\"phone-numbers-container\"></div>\n<button class=\"lp-upload-btn\" id=\"add-phone-btn\" style=\"width:100%; justify-content:center; margin-top:8px;\">\n<i class=\"fas fa-plus\"></i> إضافة رقم هاتف\n                            </button>\n</div>\n</div>\n<!-- ② Display Style Card -->\n<div class=\"lp-card\">\n<div class=\"lp-card-header\">\n<span class=\"lp-card-title\"><i class=\"fas fa-paint-roller\"></i> المظهر والتنسيق</span>\n</div>\n<div class=\"lp-section\" style=\"padding-top:0;\">\n<!-- Segmented Control for Layout Mode -->\n<div class=\"lp-segment-control\" style=\"display:flex; background:rgba(0,0,0,0.3); border-radius:8px; padding:4px; margin-bottom:12px;\">\n<label class=\"toggle-phone-text\" style=\"flex:1; text-align:center; padding:6px; cursor:pointer; font-size:0.8rem; font-weight:600; color:var(--text-secondary); transition:all 0.2s; border-radius:6px;\">\n<input name=\"phone-mode-fake\" style=\"display:none;\" type=\"radio\" value=\"text\"/>\n<i class=\"fas fa-align-left\"></i> كنص\n                                </label>\n<label class=\"toggle-phone-btn active-mode\" style=\"flex:1; text-align:center; padding:6px; cursor:pointer; font-size:0.8rem; font-weight:600; color:var(--text-secondary); transition:all 0.2s; border-radius:6px;\">\n<input checked=\"\" name=\"phone-mode-fake\" style=\"display:none;\" type=\"radio\" value=\"buttons\"/>\n<i class=\"fas fa-stop\"></i> كأزرار\n                                </label>\n<!-- Real checkbox hidden, toggled via JS to keep compatibility -->\n<input checked=\"\" id=\"toggle-phone-buttons\" style=\"display:none;\" type=\"checkbox\"/>\n</div>\n<!-- TEXT SETTINGS -->\n<div id=\"phone-text-controls\" style=\"display: none;\">\n<div class=\"lp-section lp-grid-2\" style=\"border:none; padding-bottom:0;\">\n<div>\n<label class=\"lp-label\">شكل العرض</label>\n<div class=\"lp-align-btns\">\n<label class=\"lp-align-btn lp-align-active\">\n<input checked=\"\" name=\"phone-text-layout\" type=\"radio\" value=\"row\"/> أفقي\n                                            </label>\n<label class=\"lp-align-btn\">\n<input name=\"phone-text-layout\" type=\"radio\" value=\"column\"/> رأسي\n                                            </label>\n</div>\n</div>\n<div style=\"display:flex; flex-direction:column; align-items:flex-end;\">\n<label class=\"lp-label\">اللون</label>\n<div class=\"lp-color-pick-wrap\" style=\"margin-top:2px;\">\n<input class=\"lp-color-pick\" id=\"phone-text-color\" type=\"color\" value=\"#e6f0f7\"/>\n</div>\n</div>\n</div>\n<div class=\"lp-section\">\n<label class=\"lp-label\">حجم الخط</label>\n<div class=\"lp-slider-wrap\">\n<input class=\"lp-slider\" id=\"phone-text-size\" max=\"24\" min=\"10\" oninput=\"this.nextElementSibling.textContent=this.value+'px'\" type=\"range\" value=\"14\"/>\n<span class=\"lp-slider-val\">14px</span>\n</div>\n</div>\n<div class=\"lp-section\" style=\"border:none; padding-bottom:0;\">\n<label class=\"lp-label\">الخط</label>\n<select class=\"lp-input lp-select\" id=\"phone-text-font\" style=\"height:32px; padding-top:0; padding-bottom:0;\">\n<option value=\"'Tajawal', sans-serif\">Tajawal</option>\n<option value=\"'Cairo', sans-serif\">Cairo</option>\n<option value=\"'Lalezar', cursive\">Lalezar</option>\n</select>\n</div>\n</div>\n<!-- BUTTON SETTINGS -->\n<div id=\"phone-btn-controls\">\n<div class=\"lp-section lp-grid-2\" style=\"border:none; padding-bottom:0px;\">\n<div>\n<label class=\"lp-label\">لون الزر</label>\n<div class=\"lp-color-pick-wrap\" style=\"margin-top:2px;\">\n<input class=\"lp-color-pick\" id=\"phone-btn-bg-color\" type=\"color\" value=\"#4da6ff\"/>\n</div>\n</div>\n<div style=\"display:flex; flex-direction:column; align-items:flex-end;\">\n<label class=\"lp-label\">لون النص</label>\n<div class=\"lp-color-pick-wrap\" style=\"margin-top:2px;\">\n<input class=\"lp-color-pick\" id=\"phone-btn-text-color\" type=\"color\" value=\"#ffffff\"/>\n</div>\n</div>\n</div>\n<div class=\"lp-section\">\n<label class=\"lp-label\">حجم الخط</label>\n<div class=\"lp-slider-wrap\">\n<input class=\"lp-slider\" id=\"phone-btn-font-size\" max=\"24\" min=\"10\" oninput=\"this.nextElementSibling.textContent=this.value+'px'\" type=\"range\" value=\"12\"/>\n<span class=\"lp-slider-val\">12px</span>\n</div>\n</div>\n<div class=\"lp-section\">\n<label class=\"lp-label\">التباعد (Padding)</label>\n<div class=\"lp-slider-wrap\">\n<input class=\"lp-slider\" id=\"phone-btn-padding\" max=\"16\" min=\"4\" oninput=\"this.nextElementSibling.textContent=this.value+'px'\" type=\"range\" value=\"6\"/>\n<span class=\"lp-slider-val\">6px</span>\n</div>\n</div>\n<div class=\"lp-section\" style=\"border:none; padding-bottom:0;\">\n<label class=\"lp-label\">الخط</label>\n<select class=\"lp-input lp-select\" id=\"phone-btn-font\" style=\"height:32px; padding-top:0; padding-bottom:0;\">\n<option value=\"'Poppins', sans-serif\">Poppins</option>\n<option value=\"'Tajawal', sans-serif\">Tajawal</option>\n<option value=\"'Cairo', sans-serif\">Cairo</option>\n</select>\n</div>\n</div>\n</div>\n</div>\n</div>\n</details>",
