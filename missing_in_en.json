  "lp-photo-upload-zone-click": "<div class=\"lp-upload-zone\" id=\"lp-photo-upload-zone-click\" onclick=\"document.getElementById('input-photo-upload').click();\">\n<div class=\"lp-preview-wrap\" style=\"border-radius: 50%; overflow: hidden;\">\n<img alt=\"\" class=\"lp-preview-img\" id=\"photo-preview\" src=\"\" style=\"display:none; width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: none; padding: 0;\"/>\n<div id=\"photo-placeholder\" style=\"width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(77,166,255,0.1); border-radius: 50%; border: 1px dashed rgba(77,166,255,0.4);\">\n<i class=\"fas fa-user\" style=\"font-size: 24px; color: var(--accent-primary);\"></i>\n</div>\n<div class=\"lp-spinner-wrap\"><div class=\"spinner\" id=\"photo-spinner\" style=\"display:none;\"></div></div>\n</div>\n<div class=\"lp-upload-actions\">\n<label class=\"lp-upload-btn\" style=\"pointer-events: none;\">\n<i class=\"fas fa-cloud-upload-alt\"></i> رفع صورة\n                                <small>(سيتم طلب القص)</small>\n</label>\n<input accept=\"image/*\" id=\"input-photo-upload\" style=\"display:none;\" type=\"file\"/>\n<div class=\"input-error-msg\" id=\"photo-upload-error\"></div>\n</div>\n</div>",
