                                <% if (!isFront('photo') && images.photo) { %>
                                    <div id="card-photo" class="draggable-element"
                                        style="<%= getStyle('card-personal-photo-wrapper') %>; width: <%= inputs['photo-size'] %>%; aspect-ratio: 1/1; border-radius: <%= inputs['photo-shape'] === 'circle' ? '50%' : '8px' %>; border: <%= inputs['photo-border-width'] %>px solid <%= inputs['photo-border-color'] %>; background-image: url('<%= images.photo %>'); <%= getFilterStyle('photo') %> <%= inputs['photo-glass-effect'] ? 'mix-blend-mode: screen; opacity: 0.9;' : '' %>">
                                    </div>
