<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= name %> - بطاقة عمل رقمية
    </title>

    <!-- Meta Tags for SEO & Sharing -->
    <meta name="description" content="<%= tagline || 'بطاقة عمل رقمية ذكية' %>">
    <meta property="og:title" content="<%= name %>">
    <meta property="og:description" content="<%= tagline %>">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= pageUrl %>">
    <meta name="twitter:card" content="summary_large_image">

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Cairo:wght@600;700&family=Poppins:wght@400;600&family=Tajawal:wght@400;700&family=Lalezar&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --bg-color: #121212;
            --card-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Tajawal', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 20px;
            color: #fff;
        }

        /* --- حاوية الكارت (الأساسية) --- */
        .cards-container {
            perspective: 1000px;
            width: 100%;
            display: flex;
            justify-content: center;
            margin-bottom: 30px;
        }

        .cards-wrapper {
            position: relative;
            width: 100%;
            /* الأبعاد الافتراضية (كلاسيك / عرضي) */
            max-width: 510px;
            aspect-ratio: 51 / 33;
            transform-style: preserve-3d;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
        }

        /* --- التعديل الخاص بالوضع الطولي (Vertical) --- */
        .cards-wrapper[data-layout="vertical"] {
            max-width: 330px;
            /* عرض أقل للهاتف */
            aspect-ratio: 33 / 51;
            /* عكس النسبة لتصبح طولية */
        }

        .cards-wrapper.is-flipped {
            transform: rotateY(180deg);
        }

        /* --- وجه الكارت (عام) --- */
        .business-card {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: 15px;
            overflow: hidden;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            box-shadow: var(--card-shadow);
            background-color: #000;
            /* Fallback */
        }

        .card-back {
            transform: rotateY(180deg);
        }

        /* --- الطبقات الداخلية --- */
        .card-background-layer,
        .card-gradient-layer {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            z-index: 1;
        }

        .card-gradient-layer {
            z-index: 2;
        }

        .card-content {
            position: relative;
            z-index: 3;
            width: 100%;
            height: 100%;
            padding: 5%;
            display: flex;
            flex-direction: column;
            align-items: center;
            /* هام: لضمان عمل الإحداثيات المطلقة */
            /* لكن العناصر المحفوظة تستخدم translate، لذا لا نحتاج position:relative للعناصر الأبناء بالضرورة */
        }

        /* --- العناصر المتحركة (المحفوظة بالإحداثيات) --- */
        .draggable-element {
            position: absolute;
            top: 0;
            left: 0;
            /* يتم تطبيق translate عبر inline-style */
            touch-action: none;
            /* لمنع التفاعل الخاطئ */
        }

        /* تنسيقات خاصة للعناصر */
        #card-logo {
            object-fit: contain;
        }

        #card-photo {
            background-size: cover;
            background-position: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        #card-name,
        #card-tagline {
            white-space: pre-wrap;
            text-align: center;
            margin: 0;
            line-height: 1.4;
        }

        /* أزرار الهاتف */
        .phone-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            white-space: nowrap;
            transition: transform 0.2s;
        }

        .phone-btn:active {
            transform: scale(0.95);
        }

        .phone-btn i {
            margin-inline-end: 8px;
        }

        /* أيقونات التواصل */
        .social-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border-radius: 50px;
            transition: transform 0.2s;
        }

        .social-btn:active {
            transform: scale(0.95);
        }

        .social-btn i {
            margin-inline-end: 5px;
        }

        /* QR Code */
        .qr-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 4px;
            background: #fff;
            padding: 2px;
        }

        /* --- أزرار التحكم أسفل الكارت --- */
        .actions-bar {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            flex-wrap: wrap;
            justify-content: center;
            z-index: 100;
        }

        .action-btn {
            background: #243447;
            color: #fff;
            border: 1px solid #364f6b;
            padding: 12px 24px;
            border-radius: 50px;
            text-decoration: none;
            font-family: 'Tajawal', sans-serif;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .action-btn:hover {
            background: #4da6ff;
            border-color: #4da6ff;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(77, 166, 255, 0.3);
        }

        .action-btn.primary {
            background: #4da6ff;
            border-color: #4da6ff;
        }

        .action-btn.primary:hover {
            background: #3a8ecc;
        }

        /* تلميح للتقليب */
        .flip-hint {
            margin-top: 15px;
            color: #888;
            font-size: 0.9rem;
            animation: bounce 2s infinite;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        @keyframes bounce {

            0%,
            20%,
            50%,
            80%,
            100% {
                transform: translateY(0);
            }

            40% {
                transform: translateY(-5px);
            }

            60% {
                transform: translateY(-3px);
            }
        }

        /* إخفاء الروابط المباشرة لمحركات البحث في العرض البصري (موجودة في السيرفر للـ SEO) */
        .seo-links {
            display: none;
        }

        /* --- PROFILE & NEW LAYOUT STYLES --- */
        .fade-in-up {
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInUp 0.6s ease forwards;
        }

        @keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0); }
        }

        .profile-structured-section {
            width: 100%;
            max-width: 510px;
            margin: 0 auto;
            text-align: center;
        }

        .profile-bio {
            font-size: 1.05rem;
            line-height: 1.6;
            color: #d1d5db;
            margin: 15px 0;
            padding: 0 15px;
            white-space: pre-wrap;
        }

        .availability-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.1);
        }

        .badge-available { background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); }
        .badge-freelance { background: rgba(168, 85, 247, 0.15); color: #c084fc; border: 1px solid rgba(168, 85, 247, 0.3); }
        .badge-busy { background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); }

        .pulse-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
            box-shadow: 0 0 8px currentColor;
            animation: pulse-dot-anim 1.5s infinite;
        }

        @keyframes pulse-dot-anim {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.5; }
            100% { transform: scale(1); opacity: 1; }
        }

        .secondary-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .sec-action-btn {
            background: rgba(255, 255, 255, 0.05);
            color: #e5e7eb;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 10px 18px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            backdrop-filter: blur(5px);
        }

        .sec-action-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .dynamic-links-container {
            text-align: right;
            padding: 0 5px;
        }

        .group-title {
            font-size: 1.1rem;
            color: #9ca3af;
            font-weight: 600;
            margin-bottom: 15px;
            padding-right: 5px;
            border-right: 3px solid #4da6ff;
        }

        .link-group {
            margin-bottom: 30px;
        }

        .contact-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 15px;
            margin-bottom: 12px;
            transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
            opacity: 0;
            transform: translateY(15px);
            animation: cardSlideIn 0.45s ease forwards;
        }

        .contact-card:nth-child(1) { animation-delay: 0.1s; }
        .contact-card:nth-child(2) { animation-delay: 0.2s; }
        .contact-card:nth-child(3) { animation-delay: 0.3s; }
        .contact-card:nth-child(4) { animation-delay: 0.4s; }
        .contact-card:nth-child(5) { animation-delay: 0.5s; }

        @keyframes cardSlideIn {
            to { opacity: 1; transform: translateY(0); }
        }

        .contact-card:hover {
            background: rgba(255, 255, 255, 0.06);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            transform: translateX(-4px);
        }

        .contact-card:active {
            transform: scale(0.97);
            transition: transform 0.1s ease;
        }

        .contact-card-main {
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
            flex-grow: 1;
        }

        .contact-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .contact-text {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 600;
            direction: ltr;
            text-align: right;
            word-break: break-all;
        }

        .copy-btn {
            background: transparent;
            border: none;
            color: #9ca3af;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
            flex-shrink: 0;
        }

        .copy-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }

        .copy-btn.copy-success {
            color: #2ecc71 !important;
            animation: copyPop 0.4s ease;
        }

        @keyframes copyPop {
            0% { transform: scale(1); }
            50% { transform: scale(1.3); }
            100% { transform: scale(1); }
        }

        .follow-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 12px;
        }

        .follow-pill {
            text-decoration: none;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            padding: 12px 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #fff;
            transition: all 0.2s;
        }

        .follow-pill:hover {
            border-color: var(--brand, rgba(255, 255, 255, 0.3));
            background: rgba(255, 255, 255, 0.08);
            transform: translateY(-2px);
        }

        .follow-pill i { color: var(--brand, #fff); font-size: 1.2rem; }

        .sticky-footer {
            position: fixed; bottom: 0; left: 0; width: 100%;
            background: rgba(18, 18, 18, 0.9); backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 15px 20px 25px;
            display: flex; flex-direction: column; align-items: center;
            z-index: 1000;
        }

        .save-contact-btn {
            background: linear-gradient(135deg, #4da6ff, #0077ff);
            color: #fff; border: none; width: 100%; max-width: 500px;
            padding: 16px 24px; border-radius: 50px; font-size: 1.2rem;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            cursor: pointer; box-shadow: 0 5px 20px rgba(0, 119, 255, 0.3);
            transition: transform 0.2s; font-family: inherit; font-weight: 700;
        }

        .save-contact-btn:active { transform: scale(0.98); }

        @keyframes savePulse {
            0% { box-shadow: 0 5px 20px rgba(0, 119, 255, 0.3); }
            50% { box-shadow: 0 5px 30px rgba(0, 119, 255, 0.55), 0 0 0 8px rgba(0, 119, 255, 0.1); }
            100% { box-shadow: 0 5px 20px rgba(0, 119, 255, 0.3); }
        }

        .save-contact-btn.pulse { animation: savePulse 2s ease-in-out 3; }

        .save-contact-btn.saved {
            background: linear-gradient(135deg, #2ecc71, #27ae60) !important;
            box-shadow: 0 5px 20px rgba(46, 204, 113, 0.3);
        }

        .save-contact-btn.saved i {
            animation: copyPop 0.4s ease;
        }

        .footer-powered { font-size: 0.75rem; color: #6b7280; margin-top: 10px; letter-spacing: 1px; text-transform: uppercase; }

        /* Story Generator button */
        .story-gen-btn {
            background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
            background-size: 200% 200%;
            animation: gradientShift 3s ease infinite;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .qr-modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(5px);
            z-index: 2000; display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .qr-modal-overlay.show { opacity: 1; pointer-events: auto; }
        .qr-modal-box {
            background: #1f2937; padding: 25px; border-radius: 20px; width: 90%; max-width: 350px; text-align: center;
            transform: translateY(20px); transition: transform 0.3s;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .qr-modal-overlay.show .qr-modal-box { transform: translateY(0); }
        .qr-modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .qr-modal-header h4 { margin: 0; font-size: 1.2rem; }
        .close-btn { background: transparent; border: none; color: #9ca3af; font-size: 1.5rem; cursor: pointer; }
        .qr-code-display { background: #fff; padding: 15px; border-radius: 12px; margin-bottom: 15px; display: inline-block; }
        .qr-code-display img { width: 200px; height: 200px; border-radius: 5px; }
        .qr-modal-box p { color: #9ca3af; font-size: 0.95rem; margin: 0; }

        /* --- Toast Notification System --- */
        #ejs-toast-container {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            pointer-events: none;
        }

        .ejs-toast {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            color: #fff;
            background: rgba(30, 45, 64, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(77, 166, 255, 0.3);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
            opacity: 0;
            transform: translateY(20px) scale(0.95);
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
            white-space: nowrap;
            max-width: 90vw;
        }

        .ejs-toast.show {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        .ejs-toast.toast-success { border-color: rgba(46, 204, 113, 0.4); }
        .ejs-toast.toast-success i { color: #2ecc71; }
        .ejs-toast.toast-error { border-color: rgba(231, 76, 60, 0.4); }
        .ejs-toast.toast-error i { color: #e74c3c; }
        .ejs-toast.toast-info { border-color: rgba(77, 166, 255, 0.4); }
        .ejs-toast.toast-info i { color: #4da6ff; }
    </style>
</head>

<body>

    <!-- استخراج البيانات من كائن design -->
    <% const inputs=design.inputs || {}; const dynamic=design.dynamic || {}; const images=design.imageUrls || {}; const
        positions=design.positions || {}; const placements=design.placements || {}; const
        layout=inputs['layout-select-visual'] || inputs['layout-select'] || 'classic' ; function getStyle(id) { const
        pos=positions[id] || {x:0, y:0}; return `transform: translate(${pos.x}px, ${pos.y}px);`; } function
        isFront(elementName) { const place=placements[elementName]; if (!place) { if (elementName==='logo' ) return
        true; if (elementName==='photo' ) return true; if (elementName==='name' ) return true; if
        (elementName==='tagline' ) return true; if (elementName==='qr' ) return false; return true; } return
        place==='front' ; } function getFilterStyle(prefix) { const filters=[]; if
        (inputs[`${prefix}-filter-grayscale`]) filters.push(`grayscale(${inputs[`${prefix}-filter-grayscale`]}%)`); if
        (inputs[`${prefix}-filter-sepia`]) filters.push(`sepia(${inputs[`${prefix}-filter-sepia`]}%)`); if
        (inputs[`${prefix}-filter-blur`]) filters.push(`blur(${inputs[`${prefix}-filter-blur`]}px)`); if
        (inputs[`${prefix}-filter-invert`]) filters.push(`invert(${inputs[`${prefix}-filter-invert`]}%)`); if
        (inputs[`${prefix}-filter-brightness`]) filters.push(`brightness(${inputs[`${prefix}-filter-brightness`]}%)`);
        if (inputs[`${prefix}-filter-contrast`]) filters.push(`contrast(${inputs[`${prefix}-filter-contrast`]}%)`);
        return filters.length> 0 ? `filter: ${filters.join(' ')};` : '';
        }

        function getTextStyle(prefix) {
        let style = '';
        if (inputs[`${prefix}-letter-spacing`]) style += `letter-spacing: ${inputs[`${prefix}-letter-spacing`]}px; `;
        if (inputs[`${prefix}-line-height`]) style += `line-height: ${inputs[`${prefix}-line-height`]}; `;
        if (inputs[`${prefix}-uppercase`]) style += `text-transform: uppercase; `;
        if (inputs[`${prefix}-glow`]) {
        const color = inputs[`${prefix}-color`] || '#fff';
        style += `text-shadow: 0 0 10px ${color}, 0 0 20px ${color}; `;
        }
        return style;
        }

        function getBtnStyle(prefix) {
        const styleType = inputs[`${prefix}-style`] || 'solid';
        const radius = inputs[`${prefix}-radius`] !== undefined ? inputs[`${prefix}-radius`] : 50;
        const bg = inputs[`${prefix}-bg-color`] || inputs[`back-buttons-bg-color`] || '#364f6b';
        const text = inputs[`${prefix}-text-color`] || inputs[`back-buttons-text-color`] || '#aab8c2';

        let style = `border-radius: ${radius}px; `;
        if (styleType === 'outline') {
        style += `background-color: transparent !important; color: ${bg} !important; border: 2px solid ${bg} !important;
        `;
        } else if (styleType === 'glass') {
        style += `background: rgba(255, 255, 255, 0.2) !important; backdrop-filter: blur(10px); -webkit-backdrop-filter:
        blur(10px); border: 1px solid rgba(255, 255, 255, 0.3) !important; color: ${text} !important; box-shadow: 0 4px
        6px rgba(0, 0, 0, 0.1) !important; `;
        } else {
        style += `background-color: ${bg} !important; color: ${text} !important; border: 2px solid transparent
        !important; `;
        }
        return style;
        }
        %>

        <div class="cards-container">
            <!-- تطبيق data-layout لتفعيل CSS الوضع الطولي -->
            <div class="cards-wrapper" id="card" onclick="this.classList.toggle('is-flipped'); if('vibrate' in navigator) navigator.vibrate(25);"
                data-layout="<%= layout %>">

                <!-- === الوجه الأمامي === -->
                <div class="business-card card-front">
                    <!-- الخلفية -->
                    <div class="card-background-layer"
                        style="background-image: url('<%= images.front || '' %>'); display: <%= images.front ? 'block' : 'none' %>;">
                    </div>
                    <div class="card-gradient-layer"
                        style="background: linear-gradient(135deg, <%= inputs['front-bg-start'] || '#2a3d54' %>, <%= inputs['front-bg-end'] || '#223246' %>); opacity: <%= images.front ? (inputs['front-bg-opacity'] || 0.3) : 1 %>;">
                    </div>

                    <div class="card-content">
                        <!-- العناصر الأساسية (إذا كانت في الأمام) -->
                        <% if (isFront('logo')) { %>
                            <img id="card-logo" src="<%= inputs['input-logo'] %>" class="draggable-element"
                                style="<%= getStyle('card-logo') %>; max-width: <%= inputs['logo-size'] %>%; opacity: <%= inputs['logo-opacity'] %>; <%= getFilterStyle('logo') %>">
                            <% } %>

                                <% if (isFront('photo') && images.photo) { %>
