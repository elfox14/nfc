                                                        style="<%= getStyle('card-tagline') %>; color: <%= inputs['tagline-color'] %>; font-size: <%= inputs['tagline-font-size'] %>px; font-family: <%= inputs['tagline-font'] %>; <%= getTextStyle('tagline') %>">
                                                        <%= inputs['input-tagline'] %>
                                                    </h2>
                                                    <% } %>

                                                        <% if (!isFront('qr') && inputs['qr-source'] !=='none' ) { %>
                                                            <div class="draggable-element qr-wrapper"
                                                                style="<%= getStyle('qr-code-wrapper') %>; width: <%= inputs['qr-size'] %>%;">
                                                                <img
                                                                    src="<%= images.qrCode || 'https://chart.googleapis.com/chart?cht=qr&chs=200x200&chl=' + encodeURIComponent(pageUrl) %>">
                                                            </div>
                                                            <% } %>

                                                                <!-- الهواتف (إذا كانت في الخلف) -->
                                                                <% if (dynamic.phones) { dynamic.phones.forEach(phone=>
                                                                    {
                                                                    if (phone.placement === 'back' && phone.value) { %>
                                                                    <div class="draggable-element"
                                                                        style="transform: translate(<%= phone.position.x %>px, <%= phone.position.y %>px);">
                                                                        <a href="tel:<%= phone.value %>"
                                                                            class="phone-btn" style="
                                <%= getBtnStyle('phone-btn') %>
                                font-size: <%= inputs['phone-btn-font-size'] %>px;
                                font-family: <%= inputs['phone-btn-font'] %>;
                                padding: <%= inputs['phone-btn-padding'] %>px <%= inputs['phone-btn-padding']*2 %>px;
                                <% if(inputs['toggle-phone-buttons'] === false) { %> background: transparent !important; box-shadow: none !important; border: none !important; padding: 2px !important; <% } %>
                            ">
                                                                            <i class="fas fa-phone-alt"></i>
                                                                            <span>
                                                                                <%= phone.value %>
                                                                            </span>
                                                                        </a>
                                                                    </div>
                                                                    <% }}); } %>

                                                                        <!-- روابط التواصل الاجتماعي (Static & Dynamic) -->
                                                                        <% const platforms={ whatsapp: {
                                                                            icon: 'fab fa-whatsapp' ,
                                                                            prefix: 'https://wa.me/' }, email: {
                                                                            icon: 'fas fa-envelope' , prefix: 'mailto:'
                                                                            }, website: { icon: 'fas fa-globe' ,
                                                                            prefix: '' }, facebook: {
                                                                            icon: 'fab fa-facebook-f' , prefix: '' },
                                                                            linkedin: { icon: 'fab fa-linkedin-in' ,
                                                                            prefix: '' }, instagram: {
                                                                            icon: 'fab fa-instagram' , prefix: '' }, x:
                                                                            { icon: 'fab fa-xing' , prefix: '' },
                                                                            telegram: { icon: 'fab fa-telegram' ,
                                                                            prefix: '' }, tiktok: {
                                                                            icon: 'fab fa-tiktok' , prefix: '' },
                                                                            snapchat: { icon: 'fab fa-snapchat' ,
                                                                            prefix: '' }, youtube: {
                                                                            icon: 'fab fa-youtube' , prefix: '' },
                                                                            pinterest: { icon: 'fab fa-pinterest' ,
                                                                            prefix: '' } }; // دمج القوائم (Static +
                                                                            Dynamic) const allSocials=[]; // إضافة
                                                                            الروابط الثابتة if(dynamic.staticSocial) {
                                                                            Object.entries(dynamic.staticSocial).forEach(([key,
                                                                            data])=> {
                                                                            if(data && data.value) {
                                                                            allSocials.push({ ...data, type: key,
                                                                            isStatic: true });
                                                                            }
                                                                            });
                                                                            }
                                                                            // إضافة الروابط الديناميكية
                                                                            if(dynamic.social) {
                                                                            dynamic.social.forEach(item => {
                                                                            if(item && item.value) {
                                                                            allSocials.push({ ...item, type:
                                                                            item.platform, isStatic: false });
                                                                            }
                                                                            });
                                                                            }
                                                                            %>

                                                                            <% allSocials.forEach(item=> {
                                                                                const platform = platforms[item.type] ||
                                                                                { icon: 'fas fa-link', prefix: '' };
                                                                                const btnBg =
                                                                                inputs['back-buttons-bg-color'];
                                                                                const btnColor =
                                                                                inputs['back-buttons-text-color'];
                                                                                // التحقق مما إذا كان هناك ألوان مخصصة
                                                                                const customColor = item.color ||
                                                                                inputs[`input-static-${item.type}-color`]
                                                                                || btnColor;
                                                                                const customSize = item.size ||
                                                                                inputs[`input-static-${item.type}-size`]
                                                                                || inputs['social-text-size'];

                                                                                let url = item.value;
                                                                                if (item.type === 'email' &&
                                                                                !url.startsWith('mailto:')) url =
                                                                                'mailto:' + url;
                                                                                else if (item.type === 'whatsapp') url =
                                                                                'https://wa.me/' +
