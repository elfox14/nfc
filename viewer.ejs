                                                                            <span>
                                                                                <%= phone.value %>
                                                                            </span>
                                                                        </a>
                                                                    </div>
                                                                    <% }}); } %>
                    </div>
                </div>

                <!-- === الوجه الخلفي === -->
                <div class="business-card card-back">
                    <!-- الخلفية -->
                    <div class="card-background-layer"
                        style="background-image: url('<%= images.back || '' %>'); display: <%= images.back ? 'block' : 'none' %>;">
                    </div>
                    <div class="card-gradient-layer"
                        style="background: linear-gradient(135deg, <%= inputs['back-bg-start'] || '#2a3d54' %>, <%= inputs['back-bg-end'] || '#223246' %>); opacity: <%= images.back ? (inputs['back-bg-opacity'] || 0.3) : 1 %>;">
                    </div>

                    <div class="card-content">
                        <!-- العناصر الأساسية (إذا كانت في الخلف) -->
