            </div>
        </div>

        </div>

        <div class="seo-links">
            <%- contactLinksHtml %>
        </div>

        <script>
            // UI Interactions Logic
            function openQrModal() {
                const modal = document.getElementById('qrModal');
                if (modal) {
                    modal.classList.add('show');
                    document.body.style.overflow = 'hidden';
                }
            }
            
            function closeQrModal(e) {
                if (e && e.target !== document.getElementById('qrModal') && e.target.closest('.close-btn') === null) return;
                const modal = document.getElementById('qrModal');
                if (modal) {
                    modal.classList.remove('show');
                    document.body.style.overflow = '';
                }
            }
            
            // --- Toast Notification System ---
            function showToast(message, type = 'success', duration = 3000) {
                let container = document.getElementById('ejs-toast-container');
                if (!container) {
                    container = document.createElement('div');
                    container.id = 'ejs-toast-container';
                    document.body.appendChild(container);
                }
                const iconMap = { success: 'fa-check-circle', error: 'fa-times-circle', info: 'fa-info-circle' };
                const toast = document.createElement('div');
                toast.className = 'ejs-toast toast-' + type;
                toast.innerHTML = '<i class="fas ' + (iconMap[type] || iconMap.info) + '"></i><span>' + message + '</span>';
                container.appendChild(toast);
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => { toast.classList.add('show'); });
                });
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                }, duration);
            }

            function copyToClipboard(text) {
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(text).then(() => {
                        showToast('تم النسخ بنجاح ✅', 'success', 2500);
                    }).catch(err => {
                        console.error('Failed to copy text: ', err);
                        showToast('فشل النسخ', 'error');
                    });
                } else {
                    const textArea = document.createElement("textarea");
                    textArea.value = text;
                    document.body.appendChild(textArea);
                    textArea.select();
                    try {
                        document.execCommand('copy');
                        showToast('تم النسخ بنجاح ✅', 'success', 2500);
                    } catch (err) {
                        console.error('Failed to copy text: ', err);
                        showToast('فشل النسخ', 'error');
                    }
                    document.body.removeChild(textArea);
                }
            }

            // VCF Generation Logic
            function saveContact() {
                const vcard = `BEGIN:VCARD
VERSION:3.0
FN:<%= inputs['input-name'] %>
TITLE:<%= inputs['input-tagline'] %>
<% if (dynamic.phones) { dynamic.phones.forEach(p => { %>TEL;TYPE=CELL:<%= p.value %>
<% }) } %>
<% if (dynamic.staticSocial && dynamic.staticSocial.email) { %>EMAIL:<%= dynamic.staticSocial.email.value %>
<% } %>
<% if (dynamic.staticSocial && dynamic.staticSocial.website) { %>URL:<%= dynamic.staticSocial.website.value %>
<% } %>
END:VCARD`;

                const blob = new Blob([vcard], { type: 'text/vcard' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'contact.vcf';
                a.click();
            }

            // Enhanced save with success animation
            function saveContactEnhanced() {
                saveContact();
                const btn = document.getElementById('ejs-save-btn');
                if (btn) {
                    btn.classList.add('saved');
                    const icon = btn.querySelector('i');
                    const text = btn.querySelector('span');
                    if (icon) icon.className = 'fas fa-check-circle';
                    if (text) text.textContent = 'تم الحفظ ✅';
                    showToast('تم حفظ جهة الاتصال بنجاح ✅', 'success');
                    if ('vibrate' in navigator) navigator.vibrate(40);
                    setTimeout(() => {
                        btn.classList.remove('saved');
                        if (icon) icon.className = 'fas fa-user-plus';
                        if (text) text.textContent = 'حفظ كجهة اتصال';
                    }, 3000);
                }
            }

            // Save button attention pulse
            setTimeout(() => {
                const saveBtn = document.getElementById('ejs-save-btn');
                if (saveBtn) {
                    saveBtn.classList.add('pulse');
                    saveBtn.addEventListener('animationend', () => saveBtn.classList.remove('pulse'));
                }
            }, 4000);

            // Enhanced copy with button feedback
            document.querySelectorAll('.copy-btn').forEach(btn => {
                const origClick = btn.getAttribute('onclick');
                btn.removeAttribute('onclick');
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const text = this.closest('.contact-card')?.querySelector('.contact-text')?.textContent?.trim();
                    if (text) {
                        copyToClipboard(text);
                        this.classList.add('copy-success');
                        const icon = this.querySelector('i');
                        if (icon) {
                            icon.className = 'fas fa-check';
                            setTimeout(() => {
                                icon.className = 'fas fa-copy';
                                this.classList.remove('copy-success');
                            }, 1500);
                        }
                    }
                });
            });

            async function shareCard() {
                if (navigator.share) {
                    try {
                        await navigator.share({
                            title: '<%= name %>',
                            text: 'تفضل بطاقة عملي الرقمية',
                            url: window.location.href
                        });
                    } catch (err) {
                        console.log('Share failed', err);
                    }
                } else {
                    // Fallback: Copy to clipboard
                    navigator.clipboard.writeText(window.location.href).then(() => {
                        showToast('تم نسخ رابط البطاقة 🔗', 'info', 2500);
                    });
                }
            }

            async function addToStory() {
                const frontImg = document.querySelector('#card-front-display img');
                if (!frontImg || !frontImg.src) {
                    showToast('جاري تجهيز الصورة، يرجى الانتظار...', 'info');
                    return;
                }
                
                try {
                    const res = await fetch(frontImg.src);
                    const blob = await res.blob();
                    const file = new File([blob], 'card_story.png', { type: 'image/png' });
                    
                    if (navigator.canShare && navigator.canShare({ files: [file] })) {
                        await navigator.share({
                            files: [file],
                            title: '<%= inputs["input-name"] %>',
                            text: 'اسحب للأعلى لزيارة بطاقتي!'
                        });
                    } else {
                        const a = document.createElement('a');
                        a.href = frontImg.src;
                        a.download = 'card_for_story.png';
                        a.click();
                        showToast('تم تنزيل الصورة! افتح انستجرام وأضفها للستوري 📸', 'success', 4000);
                    }
                } catch (err) {
                    console.log('Story share failed:', err);
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // STORY GENERATOR (EJS VERSION)
            // ═══════════════════════════════════════════════════════════════
            function openStoryGenerator() {
                let modal = document.getElementById('ejs-story-modal');
                if (!modal) {
                    modal = document.createElement('div');
                    modal.id = 'ejs-story-modal';
                    modal.className = 'qr-modal-overlay';
                    modal.innerHTML = `
                        <div class="qr-modal-box" style="max-width:420px;padding:0;max-height:92vh;display:flex;flex-direction:column;overflow:hidden;">
                            <!-- Header -->
                            <div style="padding:18px 20px 12px;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
                                <div class="qr-modal-header" style="margin-bottom:8px;">
                                    <h4><i class="fab fa-instagram" style="color:#E4405F;margin-left:8px;"></i> مولّد صورة الستوري</h4>
                                    <button class="close-btn" onclick="closeStoryModal()">&times;</button>
                                </div>
                                <p style="color:#9ca3af;font-size:0.85rem;margin:0;text-align:center;">اختر الثيم وحمّل صورة جاهزة للستوري</p>
                            </div>

                            <!-- Scrollable Content -->
                            <div style="flex:1;overflow-y:auto;padding:16px 20px;-webkit-overflow-scrolling:touch;">
                                <div id="ejs-story-themes" style="display:flex;gap:8px;margin-bottom:14px;justify-content:center;flex-wrap:wrap;">
                                    <button class="story-theme-opt active" data-theme="midnight" style="width:38px;height:38px;border-radius:50%;border:3px solid #4da6ff;cursor:pointer;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);box-shadow:0 0 0 3px rgba(77,166,255,0.3);transition:all 0.2s;"></button>
                                    <button class="story-theme-opt" data-theme="ocean" style="width:38px;height:38px;border-radius:50%;border:3px solid transparent;cursor:pointer;background:linear-gradient(135deg,#0077b6,#00b4d8,#90e0ef);transition:all 0.2s;"></button>
                                    <button class="story-theme-opt" data-theme="sunset" style="width:38px;height:38px;border-radius:50%;border:3px solid transparent;cursor:pointer;background:linear-gradient(135deg,#f72585,#b5179e,#7209b7);transition:all 0.2s;"></button>
                                    <button class="story-theme-opt" data-theme="forest" style="width:38px;height:38px;border-radius:50%;border:3px solid transparent;cursor:pointer;background:linear-gradient(135deg,#132a13,#31572c,#4f772d);transition:all 0.2s;"></button>
                                    <button class="story-theme-opt" data-theme="gold" style="width:38px;height:38px;border-radius:50%;border:3px solid transparent;cursor:pointer;background:linear-gradient(135deg,#1a1a2e,#c9a227,#f4d03f);transition:all 0.2s;"></button>
                                    <button class="story-theme-opt" data-theme="minimal" style="width:38px;height:38px;border-radius:50%;border:3px solid transparent;cursor:pointer;background:linear-gradient(135deg,#fafafa,#e0e0e0);transition:all 0.2s;"></button>
                                </div>
                                <div style="width:100%;aspect-ratio:9/16;border-radius:14px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,0.3);">
                                    <canvas id="ejs-story-canvas" style="width:100%;height:100%;display:block;"></canvas>
                                </div>
                            </div>

                            <!-- Sticky Action Buttons (ALWAYS VISIBLE) -->
                            <div style="padding:14px 20px 18px;border-top:1px solid rgba(255,255,255,0.08);flex-shrink:0;background:#1f2937;">
                                <button onclick="shareStory()" style="width:100%;background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);color:#fff;border:none;padding:16px;border-radius:50px;font-size:1.15rem;cursor:pointer;font-weight:800;font-family:inherit;margin-bottom:10px;box-shadow:0 4px 20px rgba(220,39,67,0.35);display:flex;align-items:center;justify-content:center;gap:10px;">
                                    <i class="fas fa-paper-plane" style="font-size:1.1rem;"></i>
                                    <span>📤 شارك الآن</span>
                                </button>
                                <div style="display:flex;gap:8px;">
                                    <button onclick="downloadStory()" style="flex:1;background:rgba(255,255,255,0.08);color:#fff;border:1px solid rgba(255,255,255,0.15);padding:12px;border-radius:50px;font-size:0.9rem;cursor:pointer;font-weight:600;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;">
                                        <i class="fas fa-download"></i> تحميل الصورة
                                    </button>
                                    <button onclick="closeStoryModal()" style="flex:1;background:rgba(255,255,255,0.05);color:#9ca3af;border:1px solid rgba(255,255,255,0.1);padding:12px;border-radius:50px;font-size:0.9rem;cursor:pointer;font-weight:600;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;">
                                        <i class="fas fa-times"></i> إغلاق
                                    </button>
                                </div>
                            </div>
                        </div>`;
                    document.body.appendChild(modal);

                    // Theme buttons
                    modal.querySelectorAll('.story-theme-opt').forEach(btn => {
                        btn.addEventListener('click', () => {
                            modal.querySelectorAll('.story-theme-opt').forEach(b => {
                                b.style.borderColor = 'transparent';
                                b.style.boxShadow = 'none';
                            });
                            btn.style.borderColor = '#4da6ff';
                            btn.style.boxShadow = '0 0 0 3px rgba(77,166,255,0.3)';
                            storyTheme = btn.dataset.theme;
                            renderEjsStory();
                        });
                    });

                    modal.addEventListener('click', e => { if (e.target === modal) closeStoryModal(); });
                }

                modal.classList.add('show');
                document.body.style.overflow = 'hidden';
                renderEjsStory();
            }

            function closeStoryModal() {
                const modal = document.getElementById('ejs-story-modal');
                if (modal) {
                    modal.classList.remove('show');
                    document.body.style.overflow = '';
                }
            }

            let storyTheme = 'midnight';
            const storyThemes = {
                midnight: { bg: ['#0f0c29', '#302b63', '#24243e'], text: '#ffffff', sub: '#a0a0c0', accent: '#4da6ff' },
                ocean:    { bg: ['#0077b6', '#00b4d8', '#90e0ef'], text: '#ffffff', sub: '#d4f1f9', accent: '#00b4d8' },
                sunset:   { bg: ['#f72585', '#b5179e', '#7209b7'], text: '#ffffff', sub: '#f0c0e0', accent: '#f72585' },
                forest:   { bg: ['#132a13', '#31572c', '#4f772d'], text: '#ffffff', sub: '#b0d0a0', accent: '#90be6d' },
                gold:     { bg: ['#1a1a2e', '#16213e', '#0f3460'], text: '#f4d03f', sub: '#c9a227', accent: '#f4d03f' },
                minimal:  { bg: ['#fafafa', '#f0f0f0', '#ffffff'], text: '#1a1a2e', sub: '#666666', accent: '#4da6ff' }
            };

            async function renderEjsStory() {
                const canvas = document.getElementById('ejs-story-canvas');
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                canvas.width = 1080;
                canvas.height = 1920;
                const theme = storyThemes[storyTheme];

                // Background
                const grad = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
                grad.addColorStop(0, theme.bg[0]);
                grad.addColorStop(0.5, theme.bg[1]);
                grad.addColorStop(1, theme.bg[2]);
                ctx.fillStyle = grad;
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Decorative circles
                ctx.fillStyle = theme.accent;
                ctx.globalAlpha = 0.1;
                ctx.beginPath(); ctx.arc(120, 180, 160, 0, Math.PI * 2); ctx.fill();
                ctx.beginPath(); ctx.arc(960, 1750, 200, 0, Math.PI * 2); ctx.fill();
                ctx.globalAlpha = 1;

                // Dot pattern
                ctx.globalAlpha = 0.03;
                for (let i = 0; i < canvas.width; i += 50) {
                    for (let j = 0; j < canvas.height; j += 50) {
                        ctx.fillStyle = theme.text;
                        ctx.beginPath(); ctx.arc(i, j, 1.5, 0, Math.PI * 2); ctx.fill();
                    }
                }
                ctx.globalAlpha = 1;

                // Tag
                ctx.textAlign = 'center';
                ctx.fillStyle = theme.accent;
                ctx.font = '600 26px "Poppins", sans-serif';
                ctx.fillText('✦  DIGITAL BUSINESS CARD  ✦', canvas.width / 2, 300);

                // Helper: draw card with rotation
                function drawCardEjs(img, x, y, w, h, rotation) {
                    ctx.save();
                    ctx.translate(x + w / 2, y + h / 2);
                    ctx.rotate(rotation * Math.PI / 180);
                    ctx.shadowColor = 'rgba(0,0,0,0.45)'; ctx.shadowBlur = 40; ctx.shadowOffsetY = 15;
                    roundR(ctx, -w/2, -h/2, w, h, 18); ctx.fillStyle = '#000'; ctx.fill();
                    ctx.shadowColor = 'transparent';
                    roundR(ctx, -w/2, -h/2, w, h, 18); ctx.clip();
                    ctx.drawImage(img, -w/2, -h/2, w, h);
                    ctx.strokeStyle = theme.accent; ctx.globalAlpha = 0.35; ctx.lineWidth = 2;
                    roundR(ctx, -w/2, -h/2, w, h, 18); ctx.stroke(); ctx.globalAlpha = 1;
                    ctx.restore();
                }

                // Dynamically load html2canvas
                if (!window.html2canvas) {
                    await new Promise(r => {
                        const s = document.createElement('script');
                        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
                        s.onload = r;
                        document.head.appendChild(s);
                    });
                }

                // Both card faces
                const frontEl = document.querySelector('.card-front');
                const backEl = document.querySelector('.card-back');
                const wrapper = document.querySelector('.cards-wrapper');

                let frontCanvasRaw = null;
                let backCanvasRaw = null;

                if (frontEl || backEl) {
                    // Temporarily flatten 3D transforms for clean capturing
                    const oldWrapperTransform = wrapper ? wrapper.style.transform : '';
                    if (wrapper) wrapper.style.transform = 'none';
                    
                    const oldBackTransform = backEl ? backEl.style.transform : '';
                    if (backEl) backEl.style.transform = 'none';

                    if (backEl) backCanvasRaw = await html2canvas(backEl, { useCORS: true, backgroundColor: null, scale: 2 });
                    if (frontEl) frontCanvasRaw = await html2canvas(frontEl, { useCORS: true, backgroundColor: null, scale: 2 });

                    // Restore transforms
                    if (wrapper) wrapper.style.transform = oldWrapperTransform;
                    if (backEl) backEl.style.transform = oldBackTransform;
                }

                const cardW = 680;
                const cardH = cardW / (51 / 33);

                // Back card (behind, rotated right)
                if (backCanvasRaw) {
                    drawCardEjs(backCanvasRaw, 240, 380, cardW, cardH, 4);
                    ctx.save(); ctx.textAlign = 'center'; ctx.fillStyle = theme.sub; ctx.globalAlpha = 0.6;
                    ctx.font = '500 22px "Tajawal", sans-serif';
                    ctx.fillText('الوجه الخلفي', 580, 380 + cardH + 55);
                    ctx.globalAlpha = 1; ctx.restore();
                }

                // Front card (on top, rotated left)
                if (frontCanvasRaw) {
                    drawCardEjs(frontCanvasRaw, 100, 430, cardW, cardH, -3);
                    ctx.save(); ctx.textAlign = 'center'; ctx.fillStyle = theme.sub; ctx.globalAlpha = 0.6;
                    ctx.font = '500 22px "Tajawal", sans-serif';
                    ctx.fillText('الوجه الأمامي', 440, 430 + cardH + 55);
                    ctx.globalAlpha = 1; ctx.restore();
                }

                // Name
                const nameY = 1100;
                ctx.fillStyle = theme.text;
                ctx.font = '800 60px "Cairo", "Tajawal", sans-serif';
                ctx.fillText('<%= inputs["input-name"] || "" %>', canvas.width / 2, nameY);

                // Tagline
                ctx.fillStyle = theme.sub;
                ctx.font = '500 34px "Tajawal", "Poppins", sans-serif';
                ctx.fillText('<%= inputs["input-tagline"] || "" %>', canvas.width / 2, nameY + 55);

                // Divider
                ctx.strokeStyle = theme.accent; ctx.globalAlpha = 0.25; ctx.lineWidth = 1;
                ctx.beginPath(); ctx.moveTo(360, nameY + 95); ctx.lineTo(720, nameY + 95); ctx.stroke();
                ctx.globalAlpha = 1;

                // QR Code
                try {
                    const qrImg = await loadImg(`https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(window.location.href)}&format=png&qzone=1`);
                    const qrX = (canvas.width - 180) / 2, qrY = nameY + 130;
                    ctx.save(); ctx.fillStyle = '#ffffff';
                    roundR(ctx, qrX - 14, qrY - 14, 208, 208, 14); ctx.fill();
                    ctx.drawImage(qrImg, qrX, qrY, 180, 180); ctx.restore();

                    ctx.fillStyle = theme.sub;
                    ctx.font = '500 24px "Tajawal", sans-serif';
                    ctx.fillText('📱 امسح الكود للتواصل', canvas.width / 2, qrY + 230);
                } catch(e) {}

                // CTA
                const ctaY = 1640;
                ctx.save();
                const ctaGrad = ctx.createLinearGradient(240, ctaY, 840, ctaY + 60);
                ctaGrad.addColorStop(0, theme.accent);
                ctaGrad.addColorStop(1, theme.accent);
                ctx.fillStyle = ctaGrad; ctx.globalAlpha = 0.15;
                roundR(ctx, 280, ctaY, 520, 60, 30); ctx.fill(); ctx.globalAlpha = 1;
                ctx.fillStyle = theme.accent;
                ctx.font = '700 26px "Tajawal", sans-serif';
                ctx.fillText('⬆ اسحب للأعلى لزيارة بطاقتي', canvas.width / 2, ctaY + 40);
                ctx.restore();

                // Branding
                ctx.fillStyle = theme.sub; ctx.globalAlpha = 0.4;
                ctx.font = '500 22px "Poppins", sans-serif';
                ctx.fillText('Powered by MC PRIME', canvas.width / 2, 1810);
                ctx.globalAlpha = 1;
            }

            function roundR(ctx, x, y, w, h, r) {
                ctx.beginPath();
                ctx.moveTo(x + r, y); ctx.lineTo(x + w - r, y);
                ctx.quadraticCurveTo(x + w, y, x + w, y + r);
                ctx.lineTo(x + w, y + h - r);
                ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
                ctx.lineTo(x + r, y + h);
                ctx.quadraticCurveTo(x, y + h, x, y + h - r);
                ctx.lineTo(x, y + r);
                ctx.quadraticCurveTo(x, y, x + r, y);
                ctx.closePath();
            }

            function loadImg(src) {
                return new Promise((resolve, reject) => {
                    const img = new Image();
                    img.crossOrigin = 'anonymous';
                    img.onload = () => resolve(img);
                    img.onerror = reject;
                    img.src = src;
                });
            }

            function downloadStory() {
                const canvas = document.getElementById('ejs-story-canvas');
                if (!canvas) return;
                try {
                    const link = document.createElement('a');
                    link.download = 'story_card.png';
                    link.href = canvas.toDataURL('image/png', 1.0);
                    link.click();
                    showToast('تم تحميل صورة الستوري 📸', 'success');
                } catch (e) {
                    console.error('Download error:', e);
                    showToast('فشل التحميل. تأكد من اتصالك بالإنترنت.', 'error');
                }
            }

            async function shareStory() {
                const canvas = document.getElementById('ejs-story-canvas');
                if (!canvas) return;
                try {
                    const blob = await new Promise(r => canvas.toBlob(r, 'image/png'));
                    const file = new File([blob], 'story_card.png', { type: 'image/png' });
                    if (navigator.canShare && navigator.canShare({ files: [file] })) {
                        await navigator.share({ files: [file], title: '<%= inputs["input-name"] || "بطاقة رقمية" %>', text: 'اسحب للأعلى لزيارة بطاقتي!' });
                    } else {
                        downloadStory();
                    }
                } catch (e) {
                    if (e.name !== 'AbortError') showToast('فشلت المشاركة', 'error');
                }
            }
        </script>
</body>

</html>