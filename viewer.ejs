<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= name %> - بطاقة عمل رقمية
    </title>

    <!-- Meta Tags for SEO & Sharing -->
    <meta name="description" content="<%= tagline || 'بطاقة عمل رقمية ذكية' %>">
    <meta property="og:title" content="<%= name %>">
    <meta property="og:description" content="<%= tagline %>">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= pageUrl %>">
    <meta name="twitter:card" content="summary_large_image">

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Cairo:wght@600;700&family=Poppins:wght@400;600&family=Tajawal:wght@400;700&family=Lalezar&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --bg-color: #121212;
            --card-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Tajawal', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 20px;
            color: #fff;
        }

        /* --- حاوية الكارت (الأساسية) --- */
        .cards-container {
            perspective: 1000px;
            width: 100%;
            display: flex;
            justify-content: center;
            margin-bottom: 30px;
        }

        .cards-wrapper {
            position: relative;
            width: 100%;
            /* الأبعاد الافتراضية (كلاسيك / عرضي) */
            max-width: 510px;
            aspect-ratio: 51 / 33;
            transform-style: preserve-3d;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
        }

        /* --- التعديل الخاص بالوضع الطولي (Vertical) --- */
        .cards-wrapper[data-layout="vertical"] {
            max-width: 330px;
            /* عرض أقل للهاتف */
            aspect-ratio: 33 / 51;
            /* عكس النسبة لتصبح طولية */
        }

        .cards-wrapper.is-flipped {
            transform: rotateY(180deg);
        }

        /* --- وجه الكارت (عام) --- */
        .business-card {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: 15px;
            overflow: hidden;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            box-shadow: var(--card-shadow);
            background-color: #000;
            /* Fallback */
        }

        .card-back {
            transform: rotateY(180deg);
        }

        /* --- الطبقات الداخلية --- */
        .card-background-layer,
        .card-gradient-layer {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            z-index: 1;
        }

        .card-gradient-layer {
            z-index: 2;
        }

        .card-content {
            position: relative;
            z-index: 3;
            width: 100%;
            height: 100%;
            padding: 5%;
            display: flex;
            flex-direction: column;
            align-items: center;
            /* هام: لضمان عمل الإحداثيات المطلقة */
            /* لكن العناصر المحفوظة تستخدم translate، لذا لا نحتاج position:relative للعناصر الأبناء بالضرورة */
        }

        /* --- العناصر المتحركة (المحفوظة بالإحداثيات) --- */
        .draggable-element {
            position: absolute;
            top: 0;
            left: 0;
            /* يتم تطبيق translate عبر inline-style */
            touch-action: none;
            /* لمنع التفاعل الخاطئ */
        }

        /* تنسيقات خاصة للعناصر */
        #card-logo {
            object-fit: contain;
        }

        #card-photo {
            background-size: cover;
            background-position: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        #card-name,
        #card-tagline {
            white-space: pre-wrap;
            text-align: center;
            margin: 0;
            line-height: 1.4;
        }

        /* أزرار الهاتف */
        .phone-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            white-space: nowrap;
            transition: transform 0.2s;
        }

        .phone-btn:active {
            transform: scale(0.95);
        }

        .phone-btn i {
            margin-inline-end: 8px;
        }

        /* أيقونات التواصل */
        .social-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border-radius: 50px;
            transition: transform 0.2s;
        }

        .social-btn:active {
            transform: scale(0.95);
        }

        .social-btn i {
            margin-inline-end: 5px;
        }

        /* QR Code */
        .qr-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 4px;
            background: #fff;
            padding: 2px;
        }

        /* --- أزرار التحكم أسفل الكارت --- */
        .actions-bar {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            flex-wrap: wrap;
            justify-content: center;
            z-index: 100;
        }

        .action-btn {
            background: #243447;
            color: #fff;
            border: 1px solid #364f6b;
            padding: 12px 24px;
            border-radius: 50px;
            text-decoration: none;
            font-family: 'Tajawal', sans-serif;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .action-btn:hover {
            background: #4da6ff;
            border-color: #4da6ff;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(77, 166, 255, 0.3);
        }

        .action-btn.primary {
            background: #4da6ff;
            border-color: #4da6ff;
        }

        .action-btn.primary:hover {
            background: #3a8ecc;
        }

        /* تلميح للتقليب */
        .flip-hint {
            margin-top: 15px;
            color: #888;
            font-size: 0.9rem;
            animation: bounce 2s infinite;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        @keyframes bounce {

            0%,
            20%,
            50%,
            80%,
            100% {
                transform: translateY(0);
            }

            40% {
                transform: translateY(-5px);
            }

            60% {
                transform: translateY(-3px);
            }
        }

        /* إخفاء الروابط المباشرة لمحركات البحث في العرض البصري (موجودة في السيرفر للـ SEO) */
        .seo-links {
            display: none;
        }

        /* --- PROFILE & NEW LAYOUT STYLES --- */
        .fade-in-up {
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInUp 0.6s ease forwards;
        }

        @keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0); }
        }

        .profile-structured-section {
            width: 100%;
            max-width: 510px;
            margin: 0 auto;
            text-align: center;
        }

        .profile-bio {
            font-size: 1.05rem;
            line-height: 1.6;
            color: #d1d5db;
            margin: 15px 0;
            padding: 0 15px;
            white-space: pre-wrap;
        }

        .availability-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.1);
        }

        .badge-available { background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); }
        .badge-freelance { background: rgba(168, 85, 247, 0.15); color: #c084fc; border: 1px solid rgba(168, 85, 247, 0.3); }
        .badge-busy { background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); }

        .pulse-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
            box-shadow: 0 0 8px currentColor;
            animation: pulse-dot-anim 1.5s infinite;
        }

        @keyframes pulse-dot-anim {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.5; }
            100% { transform: scale(1); opacity: 1; }
        }

        .secondary-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .sec-action-btn {
            background: rgba(255, 255, 255, 0.05);
            color: #e5e7eb;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 10px 18px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            backdrop-filter: blur(5px);
        }

        .sec-action-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .dynamic-links-container {
            text-align: right;
            padding: 0 5px;
        }

        .group-title {
            font-size: 1.1rem;
            color: #9ca3af;
            font-weight: 600;
            margin-bottom: 15px;
            padding-right: 5px;
            border-right: 3px solid #4da6ff;
        }

        .link-group {
            margin-bottom: 30px;
        }

        .contact-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 15px;
            margin-bottom: 12px;
            transition: transform 0.2s, background 0.2s;
        }

        .contact-card:hover {
            background: rgba(255, 255, 255, 0.06);
        }

        .contact-card-main {
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
            flex-grow: 1;
        }

        .contact-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .contact-text {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 600;
            direction: ltr;
            text-align: right;
            word-break: break-all;
        }

        .copy-btn {
            background: transparent;
            border: none;
            color: #9ca3af;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
            flex-shrink: 0;
        }

        .copy-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }

        .follow-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 12px;
        }

        .follow-pill {
            text-decoration: none;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            padding: 12px 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #fff;
            transition: all 0.2s;
        }

        .follow-pill:hover {
            border-color: var(--brand, rgba(255, 255, 255, 0.3));
            background: rgba(255, 255, 255, 0.08);
            transform: translateY(-2px);
        }

        .follow-pill i { color: var(--brand, #fff); font-size: 1.2rem; }

        .sticky-footer {
            position: fixed; bottom: 0; left: 0; width: 100%;
            background: rgba(18, 18, 18, 0.9); backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 15px 20px 25px;
            display: flex; flex-direction: column; align-items: center;
            z-index: 1000;
        }

        .save-contact-btn {
            background: linear-gradient(135deg, #4da6ff, #0077ff);
            color: #fff; border: none; width: 100%; max-width: 500px;
            padding: 16px 24px; border-radius: 50px; font-size: 1.2rem;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            cursor: pointer; box-shadow: 0 5px 20px rgba(0, 119, 255, 0.3);
            transition: transform 0.2s; font-family: inherit; font-weight: 700;
        }

        .save-contact-btn:active { transform: scale(0.98); }

        .footer-powered { font-size: 0.75rem; color: #6b7280; margin-top: 10px; letter-spacing: 1px; text-transform: uppercase; }

        .qr-modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(5px);
            z-index: 2000; display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .qr-modal-overlay.show { opacity: 1; pointer-events: auto; }
        .qr-modal-box {
            background: #1f2937; padding: 25px; border-radius: 20px; width: 90%; max-width: 350px; text-align: center;
            transform: translateY(20px); transition: transform 0.3s;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .qr-modal-overlay.show .qr-modal-box { transform: translateY(0); }
        .qr-modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .qr-modal-header h4 { margin: 0; font-size: 1.2rem; }
        .close-btn { background: transparent; border: none; color: #9ca3af; font-size: 1.5rem; cursor: pointer; }
        .qr-code-display { background: #fff; padding: 15px; border-radius: 12px; margin-bottom: 15px; display: inline-block; }
        .qr-code-display img { width: 200px; height: 200px; border-radius: 5px; }
        .qr-modal-box p { color: #9ca3af; font-size: 0.95rem; margin: 0; }

        /* --- Toast Notification System --- */
        #ejs-toast-container {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            pointer-events: none;
        }

        .ejs-toast {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            color: #fff;
            background: rgba(30, 45, 64, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(77, 166, 255, 0.3);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
            opacity: 0;
            transform: translateY(20px) scale(0.95);
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
            white-space: nowrap;
            max-width: 90vw;
        }

        .ejs-toast.show {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        .ejs-toast.toast-success { border-color: rgba(46, 204, 113, 0.4); }
        .ejs-toast.toast-success i { color: #2ecc71; }
        .ejs-toast.toast-error { border-color: rgba(231, 76, 60, 0.4); }
        .ejs-toast.toast-error i { color: #e74c3c; }
        .ejs-toast.toast-info { border-color: rgba(77, 166, 255, 0.4); }
        .ejs-toast.toast-info i { color: #4da6ff; }
    </style>
</head>

<body>

    <!-- استخراج البيانات من كائن design -->
    <% const inputs=design.inputs || {}; const dynamic=design.dynamic || {}; const images=design.imageUrls || {}; const
        positions=design.positions || {}; const placements=design.placements || {}; const
        layout=inputs['layout-select-visual'] || inputs['layout-select'] || 'classic' ; function getStyle(id) { const
        pos=positions[id] || {x:0, y:0}; return `transform: translate(${pos.x}px, ${pos.y}px);`; } function
        isFront(elementName) { const place=placements[elementName]; if (!place) { if (elementName==='logo' ) return
        true; if (elementName==='photo' ) return true; if (elementName==='name' ) return true; if
        (elementName==='tagline' ) return true; if (elementName==='qr' ) return false; return true; } return
        place==='front' ; } function getFilterStyle(prefix) { const filters=[]; if
        (inputs[`${prefix}-filter-grayscale`]) filters.push(`grayscale(${inputs[`${prefix}-filter-grayscale`]}%)`); if
        (inputs[`${prefix}-filter-sepia`]) filters.push(`sepia(${inputs[`${prefix}-filter-sepia`]}%)`); if
        (inputs[`${prefix}-filter-blur`]) filters.push(`blur(${inputs[`${prefix}-filter-blur`]}px)`); if
        (inputs[`${prefix}-filter-invert`]) filters.push(`invert(${inputs[`${prefix}-filter-invert`]}%)`); if
        (inputs[`${prefix}-filter-brightness`]) filters.push(`brightness(${inputs[`${prefix}-filter-brightness`]}%)`);
        if (inputs[`${prefix}-filter-contrast`]) filters.push(`contrast(${inputs[`${prefix}-filter-contrast`]}%)`);
        return filters.length> 0 ? `filter: ${filters.join(' ')};` : '';
        }

        function getTextStyle(prefix) {
        let style = '';
        if (inputs[`${prefix}-letter-spacing`]) style += `letter-spacing: ${inputs[`${prefix}-letter-spacing`]}px; `;
        if (inputs[`${prefix}-line-height`]) style += `line-height: ${inputs[`${prefix}-line-height`]}; `;
        if (inputs[`${prefix}-uppercase`]) style += `text-transform: uppercase; `;
        if (inputs[`${prefix}-glow`]) {
        const color = inputs[`${prefix}-color`] || '#fff';
        style += `text-shadow: 0 0 10px ${color}, 0 0 20px ${color}; `;
        }
        return style;
        }

        function getBtnStyle(prefix) {
        const styleType = inputs[`${prefix}-style`] || 'solid';
        const radius = inputs[`${prefix}-radius`] !== undefined ? inputs[`${prefix}-radius`] : 50;
        const bg = inputs[`${prefix}-bg-color`] || inputs[`back-buttons-bg-color`] || '#364f6b';
        const text = inputs[`${prefix}-text-color`] || inputs[`back-buttons-text-color`] || '#aab8c2';

        let style = `border-radius: ${radius}px; `;
        if (styleType === 'outline') {
        style += `background-color: transparent !important; color: ${bg} !important; border: 2px solid ${bg} !important;
        `;
        } else if (styleType === 'glass') {
        style += `background: rgba(255, 255, 255, 0.2) !important; backdrop-filter: blur(10px); -webkit-backdrop-filter:
        blur(10px); border: 1px solid rgba(255, 255, 255, 0.3) !important; color: ${text} !important; box-shadow: 0 4px
        6px rgba(0, 0, 0, 0.1) !important; `;
        } else {
        style += `background-color: ${bg} !important; color: ${text} !important; border: 2px solid transparent
        !important; `;
        }
        return style;
        }
        %>

        <div class="cards-container">
            <!-- تطبيق data-layout لتفعيل CSS الوضع الطولي -->
            <div class="cards-wrapper" id="card" onclick="this.classList.toggle('is-flipped'); if('vibrate' in navigator) navigator.vibrate(25);"
                data-layout="<%= layout %>">

                <!-- === الوجه الأمامي === -->
                <div class="business-card card-front">
                    <!-- الخلفية -->
                    <div class="card-background-layer"
                        style="background-image: url('<%= images.front || '' %>'); display: <%= images.front ? 'block' : 'none' %>;">
                    </div>
                    <div class="card-gradient-layer"
                        style="background: linear-gradient(135deg, <%= inputs['front-bg-start'] || '#2a3d54' %>, <%= inputs['front-bg-end'] || '#223246' %>); opacity: <%= images.front ? (inputs['front-bg-opacity'] || 0.3) : 1 %>;">
                    </div>

                    <div class="card-content">
                        <!-- العناصر الأساسية (إذا كانت في الأمام) -->
                        <% if (isFront('logo')) { %>
                            <img id="card-logo" src="<%= inputs['input-logo'] %>" class="draggable-element"
                                style="<%= getStyle('card-logo') %>; max-width: <%= inputs['logo-size'] %>%; opacity: <%= inputs['logo-opacity'] %>; <%= getFilterStyle('logo') %>">
                            <% } %>

                                <% if (isFront('photo') && images.photo) { %>
                                    <div id="card-photo" class="draggable-element"
                                        style="<%= getStyle('card-personal-photo-wrapper') %>; width: <%= inputs['photo-size'] %>%; aspect-ratio: 1/1; border-radius: <%= inputs['photo-shape'] === 'circle' ? '50%' : '8px' %>; border: <%= inputs['photo-border-width'] %>px solid <%= inputs['photo-border-color'] %>; background-image: url('<%= images.photo %>'); <%= getFilterStyle('photo') %> <%= inputs['photo-glass-effect'] ? 'mix-blend-mode: screen; opacity: 0.9;' : '' %>">
                                    </div>
                                    <% } %>

                                        <% if (isFront('name')) { %>
                                            <h1 id="card-name" class="draggable-element"
                                                style="<%= getStyle('card-name') %>; color: <%= inputs['name-color'] %>; font-size: <%= inputs['name-font-size'] %>px; font-family: <%= inputs['name-font'] %>; <%= getTextStyle('name') %>">
                                                <%= inputs['input-name'] %>
                                            </h1>
                                            <% } %>

                                                <% if (isFront('tagline')) { %>
                                                    <h2 id="card-tagline" class="draggable-element"
                                                        style="<%= getStyle('card-tagline') %>; color: <%= inputs['tagline-color'] %>; font-size: <%= inputs['tagline-font-size'] %>px; font-family: <%= inputs['tagline-font'] %>; <%= getTextStyle('tagline') %>">
                                                        <%= inputs['input-tagline'] %>
                                                    </h2>
                                                    <% } %>

                                                        <% if (isFront('qr') && inputs['qr-source'] !=='none' ) { %>
                                                            <div class="draggable-element qr-wrapper"
                                                                style="<%= getStyle('qr-code-wrapper') %>; width: <%= inputs['qr-size'] %>%;">
                                                                <img
                                                                    src="<%= images.qrCode || 'https://chart.googleapis.com/chart?cht=qr&chs=200x200&chl=' + encodeURIComponent(pageUrl) %>">
                                                            </div>
                                                            <% } %>

                                                                <!-- الهواتف (ديناميكي) -->
                                                                <% if (dynamic.phones) { dynamic.phones.forEach(phone=>
                                                                    {
                                                                    if (phone.placement === 'front' && phone.value) { %>
                                                                    <div class="draggable-element"
                                                                        style="transform: translate(<%= phone.position.x %>px, <%= phone.position.y %>px);">
                                                                        <a href="tel:<%= phone.value %>"
                                                                            class="phone-btn" style="
                                <%= getBtnStyle('phone-btn') %>
                                font-size: <%= inputs['phone-btn-font-size'] %>px;
                                font-family: <%= inputs['phone-btn-font'] %>;
                                padding: <%= inputs['phone-btn-padding'] %>px <%= inputs['phone-btn-padding']*2 %>px;
                                <% if(inputs['toggle-phone-buttons'] === false) { %> background: transparent !important; box-shadow: none !important; border: none !important; padding: 2px !important; <% } %>
                            ">
                                                                            <i class="fas fa-phone-alt"></i>
                                                                            <span>
                                                                                <%= phone.value %>
                                                                            </span>
                                                                        </a>
                                                                    </div>
                                                                    <% }}); } %>
                    </div>
                </div>

                <!-- === الوجه الخلفي === -->
                <div class="business-card card-back">
                    <!-- الخلفية -->
                    <div class="card-background-layer"
                        style="background-image: url('<%= images.back || '' %>'); display: <%= images.back ? 'block' : 'none' %>;">
                    </div>
                    <div class="card-gradient-layer"
                        style="background: linear-gradient(135deg, <%= inputs['back-bg-start'] || '#2a3d54' %>, <%= inputs['back-bg-end'] || '#223246' %>); opacity: <%= images.back ? (inputs['back-bg-opacity'] || 0.3) : 1 %>;">
                    </div>

                    <div class="card-content">
                        <!-- العناصر الأساسية (إذا كانت في الخلف) -->
                        <% if (!isFront('logo')) { %>
                            <img id="card-logo" src="<%= inputs['input-logo'] %>" class="draggable-element"
                                style="<%= getStyle('card-logo') %>; max-width: <%= inputs['logo-size'] %>%; opacity: <%= inputs['logo-opacity'] %>; <%= getFilterStyle('logo') %>">
                            <% } %>

                                <% if (!isFront('photo') && images.photo) { %>
                                    <div id="card-photo" class="draggable-element"
                                        style="<%= getStyle('card-personal-photo-wrapper') %>; width: <%= inputs['photo-size'] %>%; aspect-ratio: 1/1; border-radius: <%= inputs['photo-shape'] === 'circle' ? '50%' : '8px' %>; border: <%= inputs['photo-border-width'] %>px solid <%= inputs['photo-border-color'] %>; background-image: url('<%= images.photo %>'); <%= getFilterStyle('photo') %> <%= inputs['photo-glass-effect'] ? 'mix-blend-mode: screen; opacity: 0.9;' : '' %>">
                                    </div>
                                    <% } %>

                                        <% if (!isFront('name')) { %>
                                            <h1 id="card-name" class="draggable-element"
                                                style="<%= getStyle('card-name') %>; color: <%= inputs['name-color'] %>; font-size: <%= inputs['name-font-size'] %>px; font-family: <%= inputs['name-font'] %>; <%= getTextStyle('name') %>">
                                                <%= inputs['input-name'] %>
                                            </h1>
                                            <% } %>

                                                <% if (!isFront('tagline')) { %>
                                                    <h2 id="card-tagline" class="draggable-element"
                                                        style="<%= getStyle('card-tagline') %>; color: <%= inputs['tagline-color'] %>; font-size: <%= inputs['tagline-font-size'] %>px; font-family: <%= inputs['tagline-font'] %>; <%= getTextStyle('tagline') %>">
                                                        <%= inputs['input-tagline'] %>
                                                    </h2>
                                                    <% } %>

                                                        <% if (!isFront('qr') && inputs['qr-source'] !=='none' ) { %>
                                                            <div class="draggable-element qr-wrapper"
                                                                style="<%= getStyle('qr-code-wrapper') %>; width: <%= inputs['qr-size'] %>%;">
                                                                <img
                                                                    src="<%= images.qrCode || 'https://chart.googleapis.com/chart?cht=qr&chs=200x200&chl=' + encodeURIComponent(pageUrl) %>">
                                                            </div>
                                                            <% } %>

                                                                <!-- الهواتف (إذا كانت في الخلف) -->
                                                                <% if (dynamic.phones) { dynamic.phones.forEach(phone=>
                                                                    {
                                                                    if (phone.placement === 'back' && phone.value) { %>
                                                                    <div class="draggable-element"
                                                                        style="transform: translate(<%= phone.position.x %>px, <%= phone.position.y %>px);">
                                                                        <a href="tel:<%= phone.value %>"
                                                                            class="phone-btn" style="
                                <%= getBtnStyle('phone-btn') %>
                                font-size: <%= inputs['phone-btn-font-size'] %>px;
                                font-family: <%= inputs['phone-btn-font'] %>;
                                padding: <%= inputs['phone-btn-padding'] %>px <%= inputs['phone-btn-padding']*2 %>px;
                                <% if(inputs['toggle-phone-buttons'] === false) { %> background: transparent !important; box-shadow: none !important; border: none !important; padding: 2px !important; <% } %>
                            ">
                                                                            <i class="fas fa-phone-alt"></i>
                                                                            <span>
                                                                                <%= phone.value %>
                                                                            </span>
                                                                        </a>
                                                                    </div>
                                                                    <% }}); } %>

                                                                        <!-- روابط التواصل الاجتماعي (Static & Dynamic) -->
                                                                        <% const platforms={ whatsapp: {
                                                                            icon: 'fab fa-whatsapp' ,
                                                                            prefix: 'https://wa.me/' }, email: {
                                                                            icon: 'fas fa-envelope' , prefix: 'mailto:'
                                                                            }, website: { icon: 'fas fa-globe' ,
                                                                            prefix: '' }, facebook: {
                                                                            icon: 'fab fa-facebook-f' , prefix: '' },
                                                                            linkedin: { icon: 'fab fa-linkedin-in' ,
                                                                            prefix: '' }, instagram: {
                                                                            icon: 'fab fa-instagram' , prefix: '' }, x:
                                                                            { icon: 'fab fa-xing' , prefix: '' },
                                                                            telegram: { icon: 'fab fa-telegram' ,
                                                                            prefix: '' }, tiktok: {
                                                                            icon: 'fab fa-tiktok' , prefix: '' },
                                                                            snapchat: { icon: 'fab fa-snapchat' ,
                                                                            prefix: '' }, youtube: {
                                                                            icon: 'fab fa-youtube' , prefix: '' },
                                                                            pinterest: { icon: 'fab fa-pinterest' ,
                                                                            prefix: '' } }; // دمج القوائم (Static +
                                                                            Dynamic) const allSocials=[]; // إضافة
                                                                            الروابط الثابتة if(dynamic.staticSocial) {
                                                                            Object.entries(dynamic.staticSocial).forEach(([key,
                                                                            data])=> {
                                                                            if(data && data.value) {
                                                                            allSocials.push({ ...data, type: key,
                                                                            isStatic: true });
                                                                            }
                                                                            });
                                                                            }
                                                                            // إضافة الروابط الديناميكية
                                                                            if(dynamic.social) {
                                                                            dynamic.social.forEach(item => {
                                                                            if(item && item.value) {
                                                                            allSocials.push({ ...item, type:
                                                                            item.platform, isStatic: false });
                                                                            }
                                                                            });
                                                                            }
                                                                            %>

                                                                            <% allSocials.forEach(item=> {
                                                                                const platform = platforms[item.type] ||
                                                                                { icon: 'fas fa-link', prefix: '' };
                                                                                const btnBg =
                                                                                inputs['back-buttons-bg-color'];
                                                                                const btnColor =
                                                                                inputs['back-buttons-text-color'];
                                                                                // التحقق مما إذا كان هناك ألوان مخصصة
                                                                                const customColor = item.color ||
                                                                                inputs[`input-static-${item.type}-color`]
                                                                                || btnColor;
                                                                                const customSize = item.size ||
                                                                                inputs[`input-static-${item.type}-size`]
                                                                                || inputs['social-text-size'];

                                                                                let url = item.value;
                                                                                if (item.type === 'email' &&
                                                                                !url.startsWith('mailto:')) url =
                                                                                'mailto:' + url;
                                                                                else if (item.type === 'whatsapp') url =
                                                                                'https://wa.me/' +
                                                                                url.replace(/\D/g,'');
                                                                                else if (!url.startsWith('http')) url =
                                                                                'https://' + url;

                                                                                // التحقق من مكان العنصر (الافتراضي
                                                                                خلفي)
                                                                                const itemPlacement = item.placement ||
                                                                                'back';

                                                                                // عرض العنصر فقط إذا كان في الوجه
                                                                                الخلفي (أو الأمامي إذا أردت دعم ذلك
                                                                                للروابط)
                                                                                if (itemPlacement === 'back') {
                                                                                %>
                                                                                <div class="draggable-element"
                                                                                    style="transform: translate(<%= item.position.x %>px, <%= item.position.y %>px);">
                                                                                    <a href="<%= url %>" target="_blank"
                                                                                        class="social-btn" style="
                                <%= getBtnStyle('back-buttons') %>
                                color: <%= inputs['toggle-social-buttons'] !== false ? inputs['back-buttons-text-color'] : (customColor !== btnColor ? customColor : inputs['social-text-color']) %> !important;
                                font-size: <%= inputs['back-buttons-size'] %>px;
                                padding: <%= inputs['back-buttons-size']*0.5 %>px <%= inputs['back-buttons-size'] %>px;
                                font-family: <%= inputs['back-buttons-font'] %>;
                                <% if(inputs['toggle-social-buttons'] === false) { %> background: transparent !important; box-shadow: none !important; border: none !important; padding: 2px !important; <% } %>
                            ">
                                                                                        <i class="<%= platform.icon %>"
                                                                                            style="font-size: <%= inputs['toggle-social-buttons'] !== false ? '' : (customSize+'px') %>;"></i>
                                                                                        <span
                                                                                            style="font-size: <%= inputs['toggle-social-buttons'] !== false ? '' : (customSize+'px') %>; font-family: <%= inputs['toggle-social-buttons'] !== false ? '' : inputs['social-text-font'] %>">
                                                                                            <%= item.value %>
                                                                                        </span>
                                                                                    </a>
                                                                                </div>
                                                                                <% } }); %>

                    </div>
                </div>
            </div>

            <div class="flip-hint">
                <i class="fas fa-hand-pointer"></i> اضغط على البطاقة لقلبها
            </div>

            </div>

        <!-- === PROFILE & LINKS SECTION (MOBILE OPTIMIZED) === -->
        <div class="profile-structured-section fade-in-up" style="animation-delay: 0.2s;">
            
            <% const bio = inputs['input-bio_ar'] || inputs['input-bio_en'] || inputs['input-bio']; %>
            <% if (bio) { %>
            <div class="profile-bio">
                <%= bio %>
            </div>
            <% } %>

            <% const avail = inputs['input-availability']; %>
            <% if (avail) { 
                let badgeClass = 'badge-freelance'; let text = 'متاح لمشاريع مستقلة';
                if (avail === 'available') { badgeClass = 'badge-available'; text = 'متاح للعمل'; }
                if (avail === 'busy') { badgeClass = 'badge-busy'; text = 'مشغول حالياً'; }
            %>
            <div class="availability-badge <%= badgeClass %>">
                <span class="pulse-dot"></span> <%= text %>
            </div>
            <% } %>

            <!-- Contact Actions Row (Share / Call) replacing old actions bar -->
            <div class="secondary-actions">
                <button class="sec-action-btn" onclick="addToStory()">
                    <i class="fab fa-instagram"></i> ستوري
                </button>
                <a href="tel:<%= (dynamic.phones && dynamic.phones[0]) ? dynamic.phones[0].value.replace(/\D/g,'') : '' %>"
                    class="sec-action-btn">
                    <i class="fas fa-phone"></i> اتصال
                </a>
                <button class="sec-action-btn" onclick="shareCard()">
                    <i class="fas fa-share-alt"></i> مشاركة
                </button>
                <button class="sec-action-btn" onclick="openQrModal()">
                    <i class="fas fa-qrcode"></i> QR
                </button>
            </div>

            <!-- Dynamic Contact/Social Sections underneath -->
            <div class="dynamic-links-container">
                <!-- Group 1: Contact Methods (Phones / Email / Whatsapp) -->
                <% 
                const contactMethods = allSocials.filter(s => ['whatsapp', 'email'].includes(s.type));
                if (dynamic.phones) {
                    dynamic.phones.forEach(p => {
                        if (p.value) contactMethods.unshift({ type: 'phone', value: p.value });
                    });
                }
                const followMethods = allSocials.filter(s => !['whatsapp', 'email', 'phone'].includes(s.type));
                %>

                <% if (contactMethods.length > 0) { %>
                <div class="link-group">
                    <h3 class="group-title">تواصل معي</h3>
                    <% contactMethods.forEach(item => { 
                        let url = item.value;
                        let display = item.value;
                        let icon = 'fas fa-phone'; let color = '#4da6ff';
                        if (item.type === 'email') {
                            if (!url.startsWith('mailto:')) url = 'mailto:' + url;
                            icon = 'fas fa-envelope'; color = '#ff4d4d';
                        } else if (item.type === 'whatsapp') {
                            url = 'https://wa.me/' + url.replace(/\D/g,'');
                            icon = 'fab fa-whatsapp'; color = '#25D366';
                        } else {
                            url = 'tel:' + url.replace(/\D/g,'');
                        }
                    %>
                    <div class="contact-card">
                        <a href="<%= url %>" class="contact-card-main">
                            <div class="contact-icon" style="background: <%= color %>20; color: <%= color %>;">
                                <i class="<%= icon %>"></i>
                            </div>
                            <span class="contact-text" dir="ltr"><%= display %></span>
                        </a>
                        <button class="copy-btn" onclick="copyToClipboard('<%= display %>')" aria-label="نسخ">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                    <% }); %>
                </div>
                <% } %>

                <% if (followMethods.length > 0) { %>
                <div class="link-group">
                    <h3 class="group-title">تابعني</h3>
                    <div class="follow-grid">
                    <% followMethods.forEach(item => { 
                        let url = item.value;
                        if (!url.startsWith('http')) url = 'https://' + url;
                        const platform = platforms[item.type] || { icon: 'fas fa-link' };
                        let color = '#aab8c2';
                        const brandColors = {
                            facebook: '#1877F2', linkedin: '#0A66C2', instagram: '#E4405F',
                            x: '#ffffff', twitter: '#ffffff', tiktok: '#ff0050', youtube: '#FF0000', snapchat: '#FFFC00', telegram: '#229ED9'
                        };
                        if (brandColors[item.type]) color = brandColors[item.type];
                    %>
                        <a href="<%= url %>" target="_blank" class="follow-pill" style="--brand: <%= color %>;">
                            <i class="<%= platform.icon %>"></i>
                            <span><%= item.type.charAt(0).toUpperCase() + item.type.slice(1) %></span>
                        </a>
                    <% }); %>
                    </div>
                </div>
                <% } %>
            </div>
            
            <div style="height: 100px;"></div> <!-- Spacing for sticky footer -->
        </div>

        <!-- STICKY FOOTER -->
        <div class="sticky-footer fade-in-up" style="animation-delay: 0.4s;">
            <button class="save-contact-btn" onclick="saveContact()">
                <i class="fas fa-user-plus"></i> <span style="font-weight:700">حفظ كجهة اتصال</span>
            </button>
            <div class="footer-powered">
                Powered by MC PRIME
            </div>
        </div>

        <!-- QR Modal -->
        <div id="qrModal" class="qr-modal-overlay" onclick="closeQrModal(event)">
            <div class="qr-modal-box">
                <div class="qr-modal-header">
                    <h4>كود المشاركة السريع</h4>
                    <button class="close-btn" onclick="closeQrModal()">&times;</button>
                </div>
                <div class="qr-code-display">
                    <img src="<%= images.qrCode || 'https://chart.googleapis.com/chart?cht=qr&chs=200x200&chl=' + encodeURIComponent(pageUrl) %>" alt="QR Code">
                </div>
                <p>امسح الكود بالكاميرا لفتح البطاقة بشكل مباشر</p>
            </div>
        </div>

        </div>

        <div class="seo-links">
            <%- contactLinksHtml %>
        </div>

        <script>
            // UI Interactions Logic
            function openQrModal() {
                const modal = document.getElementById('qrModal');
                if (modal) {
                    modal.classList.add('show');
                    document.body.style.overflow = 'hidden';
                }
            }
            
            function closeQrModal(e) {
                if (e && e.target !== document.getElementById('qrModal') && e.target.closest('.close-btn') === null) return;
                const modal = document.getElementById('qrModal');
                if (modal) {
                    modal.classList.remove('show');
                    document.body.style.overflow = '';
                }
            }
            
            // --- Toast Notification System ---
            function showToast(message, type = 'success', duration = 3000) {
                let container = document.getElementById('ejs-toast-container');
                if (!container) {
                    container = document.createElement('div');
                    container.id = 'ejs-toast-container';
                    document.body.appendChild(container);
                }
                const iconMap = { success: 'fa-check-circle', error: 'fa-times-circle', info: 'fa-info-circle' };
                const toast = document.createElement('div');
                toast.className = 'ejs-toast toast-' + type;
                toast.innerHTML = '<i class="fas ' + (iconMap[type] || iconMap.info) + '"></i><span>' + message + '</span>';
                container.appendChild(toast);
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => { toast.classList.add('show'); });
                });
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                }, duration);
            }

            function copyToClipboard(text) {
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(text).then(() => {
                        showToast('تم النسخ بنجاح ✅', 'success', 2500);
                    }).catch(err => {
                        console.error('Failed to copy text: ', err);
                        showToast('فشل النسخ', 'error');
                    });
                } else {
                    const textArea = document.createElement("textarea");
                    textArea.value = text;
                    document.body.appendChild(textArea);
                    textArea.select();
                    try {
                        document.execCommand('copy');
                        showToast('تم النسخ بنجاح ✅', 'success', 2500);
                    } catch (err) {
                        console.error('Failed to copy text: ', err);
                        showToast('فشل النسخ', 'error');
                    }
                    document.body.removeChild(textArea);
                }
            }

            // VCF Generation Logic
            function saveContact() {
                const vcard = `BEGIN:VCARD
VERSION:3.0
FN:<%= inputs['input-name'] %>
TITLE:<%= inputs['input-tagline'] %>
<% if (dynamic.phones) { dynamic.phones.forEach(p => { %>TEL;TYPE=CELL:<%= p.value %>
<% }) } %>
<% if (dynamic.staticSocial && dynamic.staticSocial.email) { %>EMAIL:<%= dynamic.staticSocial.email.value %>
<% } %>
<% if (dynamic.staticSocial && dynamic.staticSocial.website) { %>URL:<%= dynamic.staticSocial.website.value %>
<% } %>
END:VCARD`;

                const blob = new Blob([vcard], { type: 'text/vcard' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'contact.vcf';
                a.click();
            }

            async function shareCard() {
                if (navigator.share) {
                    try {
                        await navigator.share({
                            title: '<%= name %>',
                            text: 'تفضل بطاقة عملي الرقمية',
                            url: window.location.href
                        });
                    } catch (err) {
                        console.log('Share failed', err);
                    }
                } else {
                    // Fallback: Copy to clipboard
                    navigator.clipboard.writeText(window.location.href).then(() => {
                        showToast('تم نسخ رابط البطاقة 🔗', 'info', 2500);
                    });
                }
            }

            async function addToStory() {
                const frontImg = document.querySelector('#card-front-display img');
                if (!frontImg || !frontImg.src) {
                    showToast('جاري تجهيز الصورة، يرجى الانتظار...', 'info');
                    return;
                }
                
                try {
                    const res = await fetch(frontImg.src);
                    const blob = await res.blob();
                    const file = new File([blob], 'card_story.png', { type: 'image/png' });
                    
                    if (navigator.canShare && navigator.canShare({ files: [file] })) {
                        await navigator.share({
                            files: [file],
                            title: '<%= inputs["input-name"] %>',
                            text: 'اسحب للأعلى لزيارة بطاقتي!'
                        });
                    } else {
                        const a = document.createElement('a');
                        a.href = frontImg.src;
                        a.download = 'card_for_story.png';
                        a.click();
                        showToast('تم تنزيل الصورة! افتح انستجرام وأضفها للستوري 📸', 'success', 4000);
                    }
                } catch (err) {
                    console.log('Story share failed:', err);
                }
            }
        </script>
</body>

</html>