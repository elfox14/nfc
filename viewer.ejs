                                                                                else if (!url.startsWith('http')) url =
                                                                                'https://' + url;

                                                                                // التحقق من مكان العنصر (الافتراضي
                                                                                خلفي)
                                                                                const itemPlacement = item.placement ||
                                                                                'back';

                                                                                // عرض العنصر فقط إذا كان في الوجه
                                                                                الخلفي (أو الأمامي إذا أردت دعم ذلك
                                                                                للروابط)
                                                                                if (itemPlacement === 'back') {
                                                                                %>
                                                                                <div class="draggable-element"
                                                                                    style="transform: translate(<%= item.position.x %>px, <%= item.position.y %>px);">
                                                                                    <a href="<%= url %>" target="_blank"
                                                                                        class="social-btn" style="
                                <%= getBtnStyle('back-buttons') %>
                                color: <%= inputs['toggle-social-buttons'] !== false ? inputs['back-buttons-text-color'] : (customColor !== btnColor ? customColor : inputs['social-text-color']) %> !important;
                                font-size: <%= inputs['back-buttons-size'] %>px;
                                padding: <%= inputs['back-buttons-size']*0.5 %>px <%= inputs['back-buttons-size'] %>px;
                                font-family: <%= inputs['back-buttons-font'] %>;
                                <% if(inputs['toggle-social-buttons'] === false) { %> background: transparent !important; box-shadow: none !important; border: none !important; padding: 2px !important; <% } %>
                            ">
                                                                                        <i class="<%= platform.icon %>"
                                                                                            style="font-size: <%= inputs['toggle-social-buttons'] !== false ? '' : (customSize+'px') %>;"></i>
                                                                                        <span
                                                                                            style="font-size: <%= inputs['toggle-social-buttons'] !== false ? '' : (customSize+'px') %>; font-family: <%= inputs['toggle-social-buttons'] !== false ? '' : inputs['social-text-font'] %>">
                                                                                            <%= item.value %>
                                                                                        </span>
                                                                                    </a>
                                                                                </div>
                                                                                <% } }); %>

                    </div>
                </div>
            </div>

            <div class="flip-hint">
                <i class="fas fa-hand-pointer"></i> اضغط على البطاقة لقلبها
            </div>

            </div>

        <!-- === PROFILE & LINKS SECTION (MOBILE OPTIMIZED) === -->
        <div class="profile-structured-section fade-in-up" style="animation-delay: 0.2s;">
            
            <% const bio = inputs['input-bio_ar'] || inputs['input-bio_en'] || inputs['input-bio']; %>
            <% if (bio) { %>
            <div class="profile-bio">
                <%= bio %>
            </div>
            <% } %>

            <% const avail = inputs['input-availability']; %>
            <% if (avail) { 
                let badgeClass = 'badge-freelance'; let text = 'متاح لمشاريع مستقلة';
                if (avail === 'available') { badgeClass = 'badge-available'; text = 'متاح للعمل'; }
                if (avail === 'busy') { badgeClass = 'badge-busy'; text = 'مشغول حالياً'; }
            %>
            <div class="availability-badge <%= badgeClass %>">
                <span class="pulse-dot"></span> <%= text %>
            </div>
            <% } %>

            <!-- Contact Actions Row (Share / Call) replacing old actions bar -->
            <div class="secondary-actions">
                <button class="sec-action-btn story-gen-btn" onclick="openStoryGenerator()">
                    <i class="fab fa-instagram"></i> ستوري
                </button>
                <a href="tel:<%= (dynamic.phones && dynamic.phones[0]) ? dynamic.phones[0].value.replace(/\D/g,'') : '' %>"
                    class="sec-action-btn">
                    <i class="fas fa-phone"></i> اتصال
                </a>
                <button class="sec-action-btn" onclick="shareCard()">
                    <i class="fas fa-share-alt"></i> مشاركة
                </button>
                <button class="sec-action-btn" onclick="openQrModal()">
                    <i class="fas fa-qrcode"></i> QR
                </button>
            </div>

            <!-- Dynamic Contact/Social Sections underneath -->
            <div class="dynamic-links-container">
                <!-- Group 1: Contact Methods (Phones / Email / Whatsapp) -->
                <% 
                const contactMethods = allSocials.filter(s => ['whatsapp', 'email'].includes(s.type));
                if (dynamic.phones) {
                    dynamic.phones.forEach(p => {
                        if (p.value) contactMethods.unshift({ type: 'phone', value: p.value });
                    });
                }
                const followMethods = allSocials.filter(s => !['whatsapp', 'email', 'phone'].includes(s.type));
                %>

                <% if (contactMethods.length > 0) { %>
                <div class="link-group">
                    <h3 class="group-title">تواصل معي</h3>
                    <% contactMethods.forEach(item => { 
                        let url = item.value;
                        let display = item.value;
                        let icon = 'fas fa-phone'; let color = '#4da6ff';
                        if (item.type === 'email') {
                            if (!url.startsWith('mailto:')) url = 'mailto:' + url;
                            icon = 'fas fa-envelope'; color = '#ff4d4d';
                        } else if (item.type === 'whatsapp') {
                            url = 'https://wa.me/' + url.replace(/\D/g,'');
                            icon = 'fab fa-whatsapp'; color = '#25D366';
                        } else {
                            url = 'tel:' + url.replace(/\D/g,'');
                        }
                    %>
                    <div class="contact-card">
                        <a href="<%= url %>" class="contact-card-main">
                            <div class="contact-icon" style="background: <%= color %>20; color: <%= color %>;">
                                <i class="<%= icon %>"></i>
                            </div>
                            <span class="contact-text" dir="ltr"><%= display %></span>
                        </a>
                        <button class="copy-btn" onclick="copyToClipboard('<%= display %>')" aria-label="نسخ">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                    <% }); %>
                </div>
                <% } %>

                <% if (followMethods.length > 0) { %>
                <div class="link-group">
                    <h3 class="group-title">تابعني</h3>
                    <div class="follow-grid">
                    <% followMethods.forEach(item => { 
                        let url = item.value;
                        if (!url.startsWith('http')) url = 'https://' + url;
                        const platform = platforms[item.type] || { icon: 'fas fa-link' };
                        let color = '#aab8c2';
                        const brandColors = {
                            facebook: '#1877F2', linkedin: '#0A66C2', instagram: '#E4405F',
                            x: '#ffffff', twitter: '#ffffff', tiktok: '#ff0050', youtube: '#FF0000', snapchat: '#FFFC00', telegram: '#229ED9'
                        };
                        if (brandColors[item.type]) color = brandColors[item.type];
                    %>
                        <a href="<%= url %>" target="_blank" class="follow-pill" style="--brand: <%= color %>;">
                            <i class="<%= platform.icon %>"></i>
                            <span><%= item.type.charAt(0).toUpperCase() + item.type.slice(1) %></span>
                        </a>
                    <% }); %>
                    </div>
                </div>
                <% } %>
            </div>
            
            <div style="height: 100px;"></div> <!-- Spacing for sticky footer -->
        </div>

        <!-- STICKY FOOTER -->
        <div class="sticky-footer fade-in-up" style="animation-delay: 0.4s;">
            <button class="save-contact-btn" id="ejs-save-btn" onclick="saveContactEnhanced()">
                <i class="fas fa-user-plus"></i> <span style="font-weight:700">حفظ كجهة اتصال</span>
            </button>
            <div class="footer-powered">
                Powered by MC PRIME
            </div>
        </div>

        <!-- QR Modal -->
        <div id="qrModal" class="qr-modal-overlay" onclick="closeQrModal(event)">
            <div class="qr-modal-box">
                <div class="qr-modal-header">
                    <h4>كود المشاركة السريع</h4>
                    <button class="close-btn" onclick="closeQrModal()">&times;</button>
                </div>
                <div class="qr-code-display">
                    <img src="<%= images.qrCode || 'https://chart.googleapis.com/chart?cht=qr&chs=200x200&chl=' + encodeURIComponent(pageUrl) %>" alt="QR Code">
                </div>
