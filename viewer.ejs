                                                style="<%= getStyle('card-name') %>; color: <%= inputs['name-color'] %>; font-size: <%= inputs['name-font-size'] %>px; font-family: <%= inputs['name-font'] %>; <%= getTextStyle('name') %>">
                                                <%= inputs['input-name'] %>
                                            </h1>
                                            <% } %>

                                                <% if (isFront('tagline')) { %>
                                                    <h2 id="card-tagline" class="draggable-element"
