{
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "jest": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-constant-condition": "warn",
    "no-control-regex": "warn",
    "no-empty": "warn",
    "no-inner-declarations": "off",
    "no-prototype-builtins": "warn",
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-useless-escape": "warn"
  }
}
