<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>عرض بطاقة عمل <%= name %> الرقمية</title>
    <meta name="description" content="اعرض بطاقة عمل <%= name %> الرقمية - <%= tagline %>. واحفظها مباشرة بصيغة PNG، PDF، أو VCF. مقدمة من MC PRIME.">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="<%= canonical %>" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/nfc/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/nfc/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/nfc/apple-touch-icon.png">
    <link rel="manifest" href="/nfc/site.webmanifest">
    
    <!-- hreflang for multilingual SEO -->
    <link rel="alternate" hreflang="ar" href="<%= pageUrl %>" />
    <link rel="alternate" hreflang="en" href="<%= pageUrl.replace('.html', '-en.html') %>" />
    <link rel="alternate" hreflang="x-default" href="<%= pageUrl %>" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="profile">
    <meta property="og:url" content="<%= pageUrl %}">
    <meta property="og:title" content="بطاقة عمل <%= name %> الرقمية | MC PRIME">
    <meta property="og:description" content="<%= tagline %> - شاهد واحفظ البطاقة الرقمية.">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:locale" content="ar_EG">
    <meta property="og:locale:alternate" content="en_US">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="<%= pageUrl %}">
    <meta property="twitter:title" content="بطاقة عمل <%= name %> الرقمية | MC PRIME">
    <meta property="twitter:description" content="<%= tagline %> - شاهد واحفظ البطاقة الرقمية.">
    <meta property="twitter:image" content="<%= ogImage %>">
    
    <!-- SEO Meta Tags -->
    <meta name="robots" content="index, follow">
    <meta name="author" content="MC PRIME">
    <meta name="keywords" content="بطاقة رقمية, NFC, بطاقة عمل, <%= name %>, <%= tagline %>, MC PRIME">
    <meta name="color-scheme" content="light dark">
    
    <!-- Preconnect for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@700&family=Poppins:wght@400;700&family=Tajawal:wght@400;700&family=Lalezar&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/nfc/viewer.css">
    
    <!-- Structured Data - Person Schema -->
    <script type="application/ld+json" nonce="<%= nonce %>">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "<%= name %>",
      "jobTitle": "<%= tagline %>",
      "url": "<%= pageUrl %>",
      "image": "<%= ogImage %>"
    }
    </script>
    
    <!-- Structured Data - LocalBusiness Schema -->
    <script type="application/ld+json" nonce="<%= nonce %>">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "MC PRIME",
      "description": "منصة متخصصة في إنشاء بطاقات الأعمال الرقمية باستخدام تقنية NFC",
      "url": "https://www.mcprim.com/nfc/",
      "logo": "https://mcprim.com/nfc/mc-prime-nfc.png",
      "image": "https://mcprim.com/nfc/mcprime-social-1200x630.png",
      "priceRange": "مجاني",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "EG"
      }
    }
    </script>
    
    <!-- Breadcrumb Schema -->
    <script type="application/ld+json" nonce="<%= nonce %>">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "الرئيسية",
          "item": "https://www.mcprim.com/nfc/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "بطاقة <%= name %>",
          "item": "<%= pageUrl %>"
        }
      ]
    }
    </script>
</head>
<body>
    <nav class="viewer-nav">
        <a href="/nfc/" class="nav-logo" title="العودة إلى الرئيسية">
            <img src="/nfc/mc-prime-nfc.png" alt="شعار MC PRIME - منصة البطاقات الرقمية">
        </a>
        <div class="nav-links">
            <a href="/nfc/">الرئيسية</a>
            <a href="/nfc/editor">إنشاء بطاقة</a>
        </div>
        
        <div class="nav-actions">
            <div class="theme-switch-wrapper">
                <label class="theme-switch" for="theme-toggle">
                    <input type="checkbox" id="theme-toggle" />
                    <span class="slider round">
                        <i class="fas fa-sun sun-icon"></i>
                        <i class="fas fa-moon moon-icon"></i>
                    </span>
                </label>
            </div>
            <a href="/nfc/editor" class="btn nav-cta">اصنع بطاقتك مجانًا</a>
        </div>
    </nav>

    <div id="loader" class="viewer-loader">
        <div class="spinner"></div>
        <p>جاري تحميل البطاقة...</p>
    </div>

    <div class="viewer-container" style="display: none;">
        <div class="viewer-layout">
            <aside class="side-column" id="left-column">
                
                <div class="profile-header" style="text-align: center; border-bottom: 1px solid var(--border-color); padding-bottom: 15px; margin-bottom: 20px;">
                    <h1 style="font-size: 1.5rem; margin: 0; color: var(--text-primary);"><%= name %></h1>
                    <% if (tagline && tagline.trim() !== '') { %>
                        <p style="font-size: 1rem; color: var(--text-secondary); margin: 5px 0 0 0;"><%= tagline %></p>
                    <% } %>
                </div>

                <h2><i class="fas fa-address-book"></i> معلومات الاتصال</h2>
                <div id="contact-links-container">
                    <%- contactLinksHtml %>
                </div>
            </aside>

            <main class="center-column">
                <div class="cards-wrapper-viewer" id="cards-wrapper-viewer" title="انقر لتقليب البطاقة">
                    <div class="business-card-viewer" id="card-front-display">
                    </div>
                    <div class="business-card-viewer" id="card-back-display" style="transform: rotateY(180deg);">
                    </div>
                </div>

                <button id="viewer-flip-btn" class="btn" aria-label="تقليب البطاقة" style="display:none; position:relative; margin-top: 15px;">
                    <i class="fas fa-sync-alt"></i> <span>تقليب البطاقة</span>
                </button>
            </main>

            <aside class="side-column save-options" id="right-column">
                <h2><i class="fas fa-download"></i> حفظ ومشاركة</h2>
                <button id="save-vcf-btn" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i>
                    حفظ جهة الاتصال (VCF)
                </button>
                <p style="font-size: 0.8rem; color: var(--text-secondary); text-align: center; margin-top: 5px; margin-bottom: 15px;">
                    (ملف لإضافة جهة الاتصال لهاتفك مباشرة)
                </p>

                <details class="fieldset-accordion">
                    <summary class="secondary-actions-summary">
                        <i class="fas fa-cog"></i> خيارات إضافية (PNG, PDF)
                    </summary>
                    <div class="fieldset-content secondary-actions-content">
                        <button id="save-front-png-btn" class="btn btn-secondary">
                            <i class="fas fa-image"></i>
                            حفظ الواجهة (PNG)
                        </button>
                        <button id="save-back-png-btn" class="btn btn-secondary">
                            <i class="fas fa-image"></i>
                            حفظ الخلفية (PNG)
                        </button>
                        <button id="save-pdf-btn" class="btn btn-secondary">
                            <i class="fas fa-file-pdf"></i>
                            حفظ كـ PDF
                        </button>
                    </div>
                </details>

                <div class="info-box">
                    <h3 class="info-box-title">
                        <i class="fas fa-info-circle"></i>
                        دليل الزائر
                    </h3>
                    <p class="info-box-text">
                        <strong>للحفظ:</strong> اضغط على <strong>"حفظ جهة الاتصال"</strong> لإضافة الملف لهاتفك.
                    </p>
                    <p class="info-box-text">
                        <strong>للمشاركة:</strong> استخدم "خيارات إضافية" لحفظ البطاقة كصورة (PNG).
                    </p>
                    
                    <h4 class="info-box-subtitle">
                        <i class="fas fa-lightbulb"></i> ميزات البطاقة الرقمية
                    </h4>
                    <ul class="info-box-list">
                        <li><i class="fas fa-check-circle c-green"></i> احفظ جهة الاتصال مباشرة</li>
                        <li><i class="fas fa-leaf c-green"></i> تحد من استهلاك الورق</li>
                        <li><i class="fas fa-edit c-blue"></i> يمكن تعديلها في أي وقت</li>
                        <li><i class="fas fa-star c-yellow"></i> انطباع عصري لا يُنسى</li>
                    </ul>
                </div>

                <a href="/nfc/editor" class="btn btn-secondary" style="margin-top: 25px; text-align: center; width: 100%;">
                    <i class="fas fa-magic"></i> أنشئ بطاقتك المجانية
                </a>
            </aside>
        </div>
    </div>

    <div class="visually-hidden">
        <div class="business-card-render-wrapper" id="front-card">
        </div>
        <div class="business-card-render-wrapper" id="back-card">
        </div>
    </div>

    <script nonce="<%= nonce %>">
        // تمرير البيانات مباشرة من الخادم إلى السكربت (لا تغيير هنا)
        window.cardData = typeof design !== 'undefined' ? <%- JSON.stringify(design) %> : {};
    </script>
    <script src="/nfc/viewer.js" nonce="<%= nonce %>"></script>
</body>
</html>
